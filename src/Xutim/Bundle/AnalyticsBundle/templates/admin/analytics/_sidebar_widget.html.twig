<turbo-frame id="analytics-sidebar">
    <div class="px-4 py-3 border-t border-border">
        <div class="flex items-center justify-between mb-2">
            <a href="{{ path('admin_analytics_page', {path: path}) }}" data-turbo-frame="_top" class="text-[11px] font-medium uppercase tracking-wider text-content-tertiary hover:text-content transition-colors">
                {{ 'Analytics (30 days)'|trans({}, 'admin') }}
            </a>
        </div>
        {% if pageStats %}
            {% if sparklineData|length > 1 %}
                <div class="mb-3 flex gap-px items-end h-8">
                    {% for data in sparklineData %}
                        {% set h = data.pageviews == 0 ? 2 : (data.pageviews / sparklineMax * 28 + 4) %}
                        <div class="flex-1 rounded-sm bg-accent/20 hover:bg-accent/40 transition-colors" style="height: {{ h }}px" title="{{ data.pageviews }} {{ 'views'|trans({}, 'admin') }}" data-controller="tooltip"></div>
                    {% endfor %}
                </div>
            {% endif %}
            <div class="grid grid-cols-3 gap-2 text-center">
                <div>
                    <div class="text-base font-semibold">{{ pageStats.pageviews|number_format(0, '.', ',') }}</div>
                    <div class="text-[10px] text-content-tertiary">{{ 'Views'|trans({}, 'admin') }}</div>
                </div>
                <div>
                    <div class="text-base font-semibold">{{ pageStats.uniqueVisitors|number_format(0, '.', ',') }}</div>
                    <div class="text-[10px] text-content-tertiary">{{ 'Visitors'|trans({}, 'admin') }}</div>
                </div>
                <div>
                    <div class="text-base font-semibold">{{ bounceRate|number_format(0) }}%</div>
                    <div class="text-[10px] text-content-tertiary">{{ 'Bounce'|trans({}, 'admin') }}</div>
                </div>
            </div>
        {% else %}
            <span class="text-content-tertiary text-[12px]">{{ 'No analytics data yet'|trans({}, 'admin') }}</span>
        {% endif %}
    </div>
</turbo-frame>
