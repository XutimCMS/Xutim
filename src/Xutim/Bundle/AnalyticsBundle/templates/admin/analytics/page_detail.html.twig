{% extends '@XutimCore/admin/base.html.twig' %}

{% macro change_indicator(current, previous, invert) %}
    {% if previous > 0 %}
        {% set change = ((current - previous) / previous * 100)|round %}
        {% if change > 0 %}
            <span class="text-{{ invert ? 'red' : 'green' }} inline-flex items-center leading-none">
                {{ change }}% <svg xmlns="http://www.w3.org/2000/svg" class="icon ml-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 17l6 -6l4 4l8 -8" /><path d="M14 7l7 0l0 7" /></svg>
            </span>
        {% elseif change < 0 %}
            <span class="text-{{ invert ? 'green' : 'red' }} inline-flex items-center leading-none">
                {{ change }}% <svg xmlns="http://www.w3.org/2000/svg" class="icon ml-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 7l6 6l4 -4l8 8" /><path d="M21 10l0 7l-7 0" /></svg>
            </span>
        {% else %}
            <span class="text-content-secondary inline-flex items-center leading-none">0%</span>
        {% endif %}
    {% elseif current > 0 %}
        <span class="text-{{ invert ? 'red' : 'green' }} inline-flex items-center leading-none">
            {{ 'New'|trans({}, 'admin') }}
        </span>
    {% endif %}
{% endmacro %}

{% block pageTitle %}{{ path }}{% endblock %}

{% block breadcrumbHeader %}
    <twig:Xutim:Admin:Breadcrumbs>
        <li class="breadcrumb-item"><a href="{{ path('admin_analytics_dashboard') }}">{{ 'Analytics'|trans({}, 'admin') }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('admin_analytics_pages', {preset: preset}) }}">{{ 'Pages'|trans({}, 'admin') }}</a></li>
        <li class="breadcrumb-item active">{{ path|u.truncate(30, '...') }}</li>
    </twig:Xutim:Admin:Breadcrumbs>
{% endblock %}

{% block pageMenu %}
    {{ include('@XutimAnalytics/admin/analytics/_date_range_selector.html.twig', {preset: preset, range: range}) }}
{% endblock %}

{% block body %}
    <div class="grid grid-cols-1 gap-4">
        <div class="col-span-1">
            <div class="rounded-xl border border-border">
                <div class="p-4">
                    <div class="text-xs font-semibold uppercase text-content-secondary mb-1">
                        <span
                            class="help-hint"
                            title="{{ 'Total number of times pages were loaded'|trans({}, 'admin') }}"
                        >
                            {{ 'Pageviews'|trans({}, 'admin') }}
                        </span>
                    </div>
                    <div class="flex items-baseline">
                        <div class="text-2xl font-bold mb-0 mr-2">{{ pageStats.pageviews|default(0)|number_format }}</div>
                        {{ _self.change_indicator(pageStats.pageviews|default(0), prevPageStats.pageviews|default(0), false) }}
                    </div>
                </div>
            </div>
        </div>
        <div class="col-span-1">
            <div class="rounded-xl border border-border">
                <div class="p-4">
                    <div class="text-xs font-semibold uppercase text-content-secondary mb-1">
                        <span
                            class="help-hint"
                            title="{{ 'Unique visitors identified by browser session'|trans({}, 'admin') }}"
                        >
                            {{ 'Visitors'|trans({}, 'admin') }}
                        </span>
                    </div>
                    <div class="flex items-baseline">
                        <div class="text-2xl font-bold mb-0 mr-2">{{ pageStats.uniqueVisitors|default(0)|number_format }}</div>
                        {{ _self.change_indicator(pageStats.uniqueVisitors|default(0), prevPageStats.uniqueVisitors|default(0), false) }}
                    </div>
                </div>
            </div>
        </div>
        <div class="col-span-1">
            <div class="rounded-xl border border-border">
                <div class="p-4">
                    <div class="text-xs font-semibold uppercase text-content-secondary mb-1">
                        <span
                            class="help-hint"
                            title="{{ 'Visitors who left after viewing only one page'|trans({}, 'admin') }}"
                        >
                            {{ 'Bounce Rate'|trans({}, 'admin') }}
                        </span>
                    </div>
                    <div class="flex items-baseline">
                        <div class="text-2xl font-bold mb-0 mr-2">{{ bounceRate ? (bounceRate|number_format(0) ~ '%') : '-' }}</div>
                        {{ _self.change_indicator(bounceRate, prevBounceRate, true) }}
                    </div>
                </div>
            </div>
        </div>
        <div class="col-span-1">
            <div class="rounded-xl border border-border">
                <div class="p-4">
                    <div class="text-xs font-semibold uppercase text-content-secondary mb-1">
                        <span
                            class="help-hint"
                            title="{{ 'Average percentage of page content scrolled'|trans({}, 'admin') }}"
                        >
                            {{ 'Avg. Scroll Depth'|trans({}, 'admin') }}
                        </span>
                    </div>
                    <div class="flex items-baseline">
                        <div class="text-2xl font-bold mb-0 mr-2">{{ pageStats.avgScrollDepth ? (pageStats.avgScrollDepth|number_format(0) ~ '%') : '-' }}</div>
                        {{ _self.change_indicator(pageStats.avgScrollDepth|default(0), prevPageStats.avgScrollDepth|default(0), false) }}
                    </div>
                </div>
            </div>
        </div>
        <div class="col-span-1">
            <div class="rounded-xl border border-border">
                <div class="p-4">
                    <div class="text-xs font-semibold uppercase text-content-secondary mb-1">
                        <span
                            class="help-hint"
                            title="{{ 'Average time for page to fully load'|trans({}, 'admin') }}"
                        >
                            {{ 'Avg. Load Time'|trans({}, 'admin') }}
                        </span>
                    </div>
                    <div class="flex items-baseline">
                        <div class="text-2xl font-bold mb-0 mr-2">{{ pageStats.avgLoadTime ? ((pageStats.avgLoadTime / 1000)|number_format(1) ~ 's') : '-' }}</div>
                        {{ _self.change_indicator(pageStats.avgLoadTime|default(0), prevPageStats.avgLoadTime|default(0), true) }}
                    </div>
                </div>
            </div>
        </div>

        <div class="col-span-full">
            <div class="rounded-xl border border-border">
                <div class="border-b border-border px-4 py-3">
                    <h3 class="text-base font-semibold">{{ 'Pageviews Over Time'|trans({}, 'admin') }}</h3>
                </div>
                <div class="p-4">
                    {% if pageviewsChart %}
                        <div style="height: 300px;">
                            {{ render_chart(pageviewsChart) }}
                        </div>
                    {% else %}
                        <table class="w-full text-[13px]">
                            <thead>
                                <tr>
                                    <th>{{ 'Date'|trans({}, 'admin') }}</th>
                                    <th class="text-right">{{ 'Views'|trans({}, 'admin') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for row in pageviewsByDay %}
                                    <tr>
                                        <td>{{ row.date }}</td>
                                        <td class="text-right">{{ row.pageviews|number_format }}</td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="2" class="text-content-secondary">{{ 'No data'|trans({}, 'admin') }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-span-full">
            <div class="rounded-xl border border-border">
                <div class="border-b border-border px-4 py-3">
                    <h3 class="text-base font-semibold">{{ 'Referrers'|trans({}, 'admin') }}</h3>
                </div>
                <div class="overflow-x-auto">
                    {% set maxRefCount = referrers|map(r => r.visits)|sort|last|default(1) %}
                    <table class="w-full text-[13px]">
                        <thead>
                            <tr>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'Referrer'|trans({}, 'admin') }}</th>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'Type'|trans({}, 'admin') }}</th>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'Visits'|trans({}, 'admin') }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for referrer in referrers %}
                                <tr>
                                    <td class="truncate" style="max-width: 300px;" title="{{ referrer.referrer }}">
                                        {% if referrer.isExternal %}
                                            {{ referrer.referrer|u.truncate(50, '...') }}
                                        {% else %}
                                            <a href="{{ path('admin_analytics_page', {path: referrer.referrer, preset: preset}) }}">
                                                {{ referrer.referrer|u.truncate(50, '...') }}
                                            </a>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if referrer.isExternal %}
                                            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium bg-blue-100 text-blue-700 dark:bg-blue-500/20 dark:text-blue-400">{{ 'External'|trans({}, 'admin') }}</span>
                                        {% else %}
                                            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium bg-green-100 text-green-700 dark:bg-green-500/20 dark:text-green-400">{{ 'Internal'|trans({}, 'admin') }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-content-secondary">{{ referrer.visits|number_format }}</td>
                                    <td class="w-25">
                                        <div class="h-1 w-full rounded-full bg-surface-raised overflow-hidden">
                                            <div class="h-full rounded-full bg-amber-500" style="width: {{ (referrer.visits / maxRefCount * 100)|round }}%"></div>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4" class="text-content-secondary">{{ 'No data'|trans({}, 'admin') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
