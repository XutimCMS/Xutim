{% extends '@XutimCore/admin/base.html.twig' %}

{% block pageTitle %}{{ 'Devices'|trans({}, 'admin') }}{% endblock %}

{% block breadcrumbHeader %}
    <twig:Xutim:Admin:Breadcrumbs>
        <li class="breadcrumb-item"><a href="{{ path('admin_analytics_dashboard') }}">{{ 'Analytics'|trans({}, 'admin') }}</a></li>
        <li class="breadcrumb-item active">{{ 'Devices'|trans({}, 'admin') }}</li>
    </twig:Xutim:Admin:Breadcrumbs>
{% endblock %}

{% block pageMenu %}
    {{ include('@XutimAnalytics/admin/analytics/_date_range_selector.html.twig', {preset: preset, range: range}) }}
{% endblock %}

{% block body %}
    <div class="grid grid-cols-1 gap-4">
        <div class="lg:col-span-4">
            <div class="rounded-xl border border-border">
                <div class="border-b border-border px-4 py-3">
                    <h3 class="text-base font-semibold">{{ 'Device Types'|trans({}, 'admin') }}</h3>
                </div>
                <div class="overflow-x-auto">
                    {% set maxDeviceCount = devices|map(d => d.visits)|sort|last|default(1) %}
                    <table class="w-full text-[13px]">
                        <thead>
                            <tr>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'Device'|trans({}, 'admin') }}</th>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'Visitors'|trans({}, 'admin') }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for device in devices %}
                                <tr>
                                    <td>{{ device.deviceType }}</td>
                                    <td class="text-content-secondary">{{ device.visits|number_format }}</td>
                                    <td class="w-1/2">
                                        <div class="h-1 w-full rounded-full bg-surface-raised overflow-hidden">
                                            <div class="h-full rounded-full bg-amber-500" style="width: {{ (device.visits / maxDeviceCount * 100)|round }}%"></div>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="3" class="text-content-secondary">{{ 'No data'|trans({}, 'admin') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="lg:col-span-4">
            <div class="rounded-xl border border-border">
                <div class="border-b border-border px-4 py-3">
                    <h3 class="text-base font-semibold">{{ 'Browsers'|trans({}, 'admin') }}</h3>
                </div>
                <div class="overflow-x-auto">
                    {% set maxBrowserCount = browsers|map(b => b.visits)|sort|last|default(1) %}
                    <table class="w-full text-[13px]">
                        <thead>
                            <tr>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'Browser'|trans({}, 'admin') }}</th>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'Visitors'|trans({}, 'admin') }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for browser in browsers %}
                                <tr>
                                    <td>{{ browser.browser }}</td>
                                    <td class="text-content-secondary">{{ browser.visits|number_format }}</td>
                                    <td class="w-1/2">
                                        <div class="h-1 w-full rounded-full bg-surface-raised overflow-hidden">
                                            <div class="h-full rounded-full bg-amber-500" style="width: {{ (browser.visits / maxBrowserCount * 100)|round }}%"></div>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="3" class="text-content-secondary">{{ 'No data'|trans({}, 'admin') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="lg:col-span-4">
            <div class="rounded-xl border border-border">
                <div class="border-b border-border px-4 py-3">
                    <h3 class="text-base font-semibold">{{ 'Operating Systems'|trans({}, 'admin') }}</h3>
                </div>
                <div class="overflow-x-auto">
                    {% set maxOsCount = operatingSystems|map(o => o.visits)|sort|last|default(1) %}
                    <table class="w-full text-[13px]">
                        <thead>
                            <tr>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'OS'|trans({}, 'admin') }}</th>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'Visitors'|trans({}, 'admin') }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for os in operatingSystems %}
                                <tr>
                                    <td>{{ os.os }}</td>
                                    <td class="text-content-secondary">{{ os.visits|number_format }}</td>
                                    <td class="w-1/2">
                                        <div class="h-1 w-full rounded-full bg-surface-raised overflow-hidden">
                                            <div class="h-full rounded-full bg-amber-500" style="width: {{ (os.visits / maxOsCount * 100)|round }}%"></div>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="3" class="text-content-secondary">{{ 'No data'|trans({}, 'admin') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
