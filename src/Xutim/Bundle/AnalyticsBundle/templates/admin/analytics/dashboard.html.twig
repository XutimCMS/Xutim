{% extends '@XutimCore/admin/base.html.twig' %}

{% macro change_indicator(current, previous, invert) %}
    {% if previous > 0 %}
        {% set change = ((current - previous) / previous * 100)|round %}
        {% if change > 0 %}
            <span class="text-{{ invert ? 'red' : 'green' }} inline-flex items-center leading-none">
                {{ change }}% <svg xmlns="http://www.w3.org/2000/svg" class="icon ml-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 17l6 -6l4 4l8 -8" /><path d="M14 7l7 0l0 7" /></svg>
            </span>
        {% elseif change < 0 %}
            <span class="text-{{ invert ? 'green' : 'red' }} inline-flex items-center leading-none">
                {{ change }}% <svg xmlns="http://www.w3.org/2000/svg" class="icon ml-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 7l6 6l4 -4l8 8" /><path d="M21 10l0 7l-7 0" /></svg>
            </span>
        {% else %}
            <span class="text-content-secondary inline-flex items-center leading-none">0%</span>
        {% endif %}
    {% elseif current > 0 %}
        <span class="text-{{ invert ? 'red' : 'green' }} inline-flex items-center leading-none">
            {{ 'New'|trans({}, 'admin') }}
        </span>
    {% endif %}
{% endmacro %}

{% block pageTitle %}{{ 'Analytics'|trans({}, 'admin') }}{% endblock %}

{% block breadcrumbHeader %}
    <twig:Xutim:Admin:Breadcrumbs>
        <li class="breadcrumb-item active">{{ 'Analytics'|trans({}, 'admin') }}</li>
    </twig:Xutim:Admin:Breadcrumbs>
{% endblock %}

{% block pageMenu %}
    {{ include('@XutimAnalytics/admin/analytics/_date_range_selector.html.twig', {preset: preset, range: range}) }}
{% endblock %}

{% block body %}
    <div class="grid grid-cols-1 gap-4">
        <div class="sm:col-span-3 lg:col-span-1">
            <div class="rounded-xl border border-border">
                <div class="p-4">
                    <div class="text-xs font-semibold uppercase text-content-secondary mb-1">
                        <span
                            class="help-hint"
                            title="{{ 'Total number of times pages were loaded'|trans({}, 'admin') }}"
                        >
                            {{ 'Pageviews'|trans({}, 'admin') }}
                        </span>
                    </div>
                    <div class="flex items-baseline">
                        <div class="text-2xl font-bold mb-0 mr-2">{{ pageviews|number_format }}</div>
                        {{ _self.change_indicator(pageviews, prevPageviews, false) }}
                    </div>
                </div>
            </div>
        </div>
        <div class="sm:col-span-3 lg:col-span-1">
            <div class="rounded-xl border border-border">
                <div class="p-4">
                    <div class="text-xs font-semibold uppercase text-content-secondary mb-1">
                        <span
                            class="help-hint"
                            title="{{ 'Unique visitors identified by browser session'|trans({}, 'admin') }}"
                        >
                            {{ 'Visitors'|trans({}, 'admin') }}
                        </span>
                    </div>
                    <div class="flex items-baseline">
                        <div class="text-2xl font-bold mb-0 mr-2">{{ visitors|number_format }}</div>
                        {{ _self.change_indicator(visitors, prevVisitors, false) }}
                    </div>
                </div>
            </div>
        </div>
        <div class="sm:col-span-3 lg:col-span-1">
            <div class="rounded-xl border border-border">
                <div class="p-4">
                    <div class="text-xs font-semibold uppercase text-content-secondary mb-1">
                        <span
                            class="help-hint"
                            title="{{ 'Average number of pages viewed per session'|trans({}, 'admin') }}"
                        >
                            {{ 'Views/Visit'|trans({}, 'admin') }}
                        </span>
                    </div>
                    <div class="flex items-baseline">
                        <div class="text-2xl font-bold mb-0 mr-2">{{ viewsPerVisit ? viewsPerVisit|number_format(1) : '-' }}</div>
                        {{ _self.change_indicator(viewsPerVisit, prevViewsPerVisit, false) }}
                    </div>
                </div>
            </div>
        </div>
        <div class="sm:col-span-3 lg:col-span-1">
            <div class="rounded-xl border border-border">
                <div class="p-4">
                    <div class="text-xs font-semibold uppercase text-content-secondary mb-1">
                        <span
                            class="help-hint"
                            title="{{ 'Visitors who left after viewing only one page'|trans({}, 'admin') }}"
                        >
                            {{ 'Bounce Rate'|trans({}, 'admin') }}
                        </span>
                    </div>
                    <div class="flex items-baseline">
                        <div class="text-2xl font-bold mb-0 mr-2">{{ bounceRate ? (bounceRate|number_format(0) ~ '%') : '-' }}</div>
                        {{ _self.change_indicator(bounceRate, prevBounceRate, true) }}
                    </div>
                </div>
            </div>
        </div>
        <div class="sm:col-span-3 lg:col-span-1">
            <div class="rounded-xl border border-border">
                <div class="p-4">
                    <div class="text-xs font-semibold uppercase text-content-secondary mb-1">
                        <span
                            class="help-hint"
                            title="{{ 'Average percentage of page content scrolled'|trans({}, 'admin') }}"
                        >
                            {{ 'Avg. Scroll Depth'|trans({}, 'admin') }}
                        </span>
                    </div>
                    <div class="flex items-baseline">
                        <div class="text-2xl font-bold mb-0 mr-2">{{ avgScrollDepth ? (avgScrollDepth|number_format(0) ~ '%') : '-' }}</div>
                        {{ _self.change_indicator(avgScrollDepth, prevAvgScrollDepth, false) }}
                    </div>
                </div>
            </div>
        </div>
        <div class="sm:col-span-3 lg:col-span-1">
            <div class="rounded-xl border border-border">
                <div class="p-4">
                    <div class="text-xs font-semibold uppercase text-content-secondary mb-1">
                        <span
                            class="help-hint"
                            title="{{ 'Average time for page to fully load'|trans({}, 'admin') }}"
                        >
                            {{ 'Avg. Load Time'|trans({}, 'admin') }}
                        </span>
                    </div>
                    <div class="flex items-baseline">
                        <div class="text-2xl font-bold mb-0 mr-2">{{ avgLoadTime ? ((avgLoadTime / 1000)|number_format(1) ~ 's') : '-' }}</div>
                        {{ _self.change_indicator(avgLoadTime, prevAvgLoadTime, true) }}
                    </div>
                </div>
            </div>
        </div>

        <div class="col-span-full">
            <div class="rounded-xl border border-border">
                <div class="border-b border-border px-4 py-3">
                    <h3 class="text-base font-semibold">{{ 'Pageviews'|trans({}, 'admin') }}</h3>
                </div>
                <div class="p-4">
                    {% if pageviewsChart %}
                        <div style="height: 300px;">
                            {{ render_chart(pageviewsChart) }}
                        </div>
                    {% else %}
                        <table class="w-full text-[13px]">
                            <thead>
                                <tr>
                                    <th>{{ 'Date'|trans({}, 'admin') }}</th>
                                    <th class="text-right">{{ 'Views'|trans({}, 'admin') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for row in pageviewsByDay %}
                                    <tr>
                                        <td>{{ row.date }}</td>
                                        <td class="text-right">{{ row.pageviews|number_format }}</td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="2" class="text-content-secondary">{{ 'No data'|trans({}, 'admin') }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="lg:col-span-6">
            <div class="rounded-xl border border-border">
                <div class="border-b border-border px-4 py-3">
                    <h3 class="text-base font-semibold">{{ 'Top Pages'|trans({}, 'admin') }}</h3>
                    <div class="ml-auto">
                        <a href="{{ path('admin_analytics_pages', {preset: preset}) }}" class="text-accent hover:text-accent/80">
                            {{ 'View all'|trans({}, 'admin') }}
                        </a>
                    </div>
                </div>
                <div class="overflow-x-auto">
                    {% set maxPageViews = topPages|map(p => p.totalPageviews)|sort|last|default(1) %}
                    <table class="w-full text-[13px]">
                        <thead>
                            <tr>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'Page'|trans({}, 'admin') }}</th>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'Views'|trans({}, 'admin') }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for page in topPages %}
                                <tr>
                                    <td>
                                        <a href="{{ path('admin_analytics_page', {path: page.path, preset: preset}) }}">
                                            {{ page.path|u.truncate(40, '...') }}
                                        </a>
                                    </td>
                                    <td class="text-content-secondary">{{ page.totalPageviews|number_format }}</td>
                                    <td class="w-1/2">
                                        <div class="h-1 w-full rounded-full bg-surface-raised overflow-hidden">
                                            <div class="h-full rounded-full bg-amber-500" style="width: {{ (page.totalPageviews / maxPageViews * 100)|round }}%"></div>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="3" class="text-content-secondary">{{ 'No data'|trans({}, 'admin') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="lg:col-span-6">
            <div class="rounded-xl border border-border">
                <div class="border-b border-border px-4 py-3">
                    <h3 class="text-base font-semibold">{{ 'Traffic Sources'|trans({}, 'admin') }}</h3>
                    <div class="ml-auto">
                        <a href="{{ path('admin_analytics_sources', {preset: preset}) }}" class="text-accent hover:text-accent/80">
                            {{ 'View all'|trans({}, 'admin') }}
                        </a>
                    </div>
                </div>
                <div class="overflow-x-auto">
                    {% set maxSourceCount = referrers|map(r => r.visits)|sort|last|default(1) %}
                    <table class="w-full text-[13px]">
                        <thead>
                            <tr>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'Source'|trans({}, 'admin') }}</th>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'Visits'|trans({}, 'admin') }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for source in referrers %}
                                <tr>
                                    <td>{{ source.source }}</td>
                                    <td class="text-content-secondary">{{ source.visits|number_format }}</td>
                                    <td class="w-1/2">
                                        <div class="h-1 w-full rounded-full bg-surface-raised overflow-hidden">
                                            <div class="h-full rounded-full bg-amber-500" style="width: {{ (source.visits / maxSourceCount * 100)|round }}%"></div>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="3" class="text-content-secondary">{{ 'No data'|trans({}, 'admin') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="lg:col-span-6">
            <div class="rounded-xl border border-border">
                <div class="border-b border-border px-4 py-3">
                    <h3 class="text-base font-semibold">{{ 'Countries'|trans({}, 'admin') }}</h3>
                    <div class="ml-auto">
                        <a href="{{ path('admin_analytics_geography', {preset: preset}) }}" class="text-accent hover:text-accent/80">
                            {{ 'View all'|trans({}, 'admin') }}
                        </a>
                    </div>
                </div>
                <div class="overflow-x-auto">
                    {% set maxCountryCount = countries|map(c => c.visits)|sort|last|default(1) %}
                    <table class="w-full text-[13px]">
                        <thead>
                            <tr>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'Country'|trans({}, 'admin') }}</th>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'Visitors'|trans({}, 'admin') }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for country in countries %}
                                <tr>
                                    <td>{{ country.country|country_name|default(country.country) }}</td>
                                    <td class="text-content-secondary">{{ country.visits|number_format }}</td>
                                    <td class="w-1/2">
                                        <div class="h-1 w-full rounded-full bg-surface-raised overflow-hidden">
                                            <div class="h-full rounded-full bg-amber-500" style="width: {{ (country.visits / maxCountryCount * 100)|round }}%"></div>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="3" class="text-content-secondary">{{ 'No data'|trans({}, 'admin') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="lg:col-span-6">
            <div class="rounded-xl border border-border">
                <div class="border-b border-border px-4 py-3">
                    <h3 class="text-base font-semibold">{{ 'Devices'|trans({}, 'admin') }}</h3>
                    <div class="ml-auto">
                        <a href="{{ path('admin_analytics_devices', {preset: preset}) }}" class="text-accent hover:text-accent/80">
                            {{ 'View all'|trans({}, 'admin') }}
                        </a>
                    </div>
                </div>
                <div class="overflow-x-auto">
                    {% set maxDeviceCount = devices|map(d => d.visits)|sort|last|default(1) %}
                    <table class="w-full text-[13px]">
                        <thead>
                            <tr>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'Device'|trans({}, 'admin') }}</th>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'Visitors'|trans({}, 'admin') }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for device in devices %}
                                <tr>
                                    <td>{{ device.deviceType }}</td>
                                    <td class="text-content-secondary">{{ device.visits|number_format }}</td>
                                    <td class="w-1/2">
                                        <div class="h-1 w-full rounded-full bg-surface-raised overflow-hidden">
                                            <div class="h-full rounded-full bg-amber-500" style="width: {{ (device.visits / maxDeviceCount * 100)|round }}%"></div>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="3" class="text-content-secondary">{{ 'No data'|trans({}, 'admin') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
