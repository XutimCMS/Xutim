{% extends '@XutimCore/admin/base.html.twig' %}

{% block pageTitle %}{{ 'Traffic Sources'|trans({}, 'admin') }}{% endblock %}

{% block breadcrumbHeader %}
    <twig:Xutim:Admin:Breadcrumbs>
        <li class="breadcrumb-item"><a href="{{ path('admin_analytics_dashboard') }}">{{ 'Analytics'|trans({}, 'admin') }}</a></li>
        <li class="breadcrumb-item active">{{ 'Traffic Sources'|trans({}, 'admin') }}</li>
    </twig:Xutim:Admin:Breadcrumbs>
{% endblock %}

{% block pageMenu %}
    {{ include('@XutimAnalytics/admin/analytics/_date_range_selector.html.twig', {preset: preset, range: range}) }}
{% endblock %}

{% block body %}
    <div class="grid grid-cols-1 gap-4">
        <div class="lg:col-span-6">
            <div class="rounded-xl border border-border">
                <div class="border-b border-border px-4 py-3">
                    <h3 class="text-base font-semibold">
                        <span
                            class="help-hint"
                            title="{{ 'Categorized traffic origin (e.g., google, direct)'|trans({}, 'admin') }}"
                        >
                            {{ 'Sources'|trans({}, 'admin') }}
                        </span>
                    </h3>
                </div>
                <div class="overflow-x-auto">
                    {% set maxSourceCount = sources|map(s => s.visits)|sort|last|default(1) %}
                    <table class="w-full text-[13px]">
                        <thead>
                            <tr>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'Source'|trans({}, 'admin') }}</th>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'Visits'|trans({}, 'admin') }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for source in sources %}
                                <tr>
                                    <td>{{ source.source }}</td>
                                    <td class="text-content-secondary">{{ source.visits|number_format }}</td>
                                    <td class="w-1/2">
                                        <div class="h-1 w-full rounded-full bg-surface-raised overflow-hidden">
                                            <div class="h-full rounded-full bg-amber-500" style="width: {{ (source.visits / maxSourceCount * 100)|round }}%"></div>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="3" class="text-content-secondary">{{ 'No data'|trans({}, 'admin') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="lg:col-span-6">
            <div class="rounded-xl border border-border">
                <div class="border-b border-border px-4 py-3">
                    <h3 class="text-base font-semibold">
                        <span
                            class="help-hint"
                            title="{{ 'Full URLs that referred traffic to your site'|trans({}, 'admin') }}"
                        >
                            {{ 'Referrer URLs'|trans({}, 'admin') }}
                        </span>
                    </h3>
                </div>
                <div class="overflow-x-auto">
                    {% set maxRefCount = rawReferrers|map(r => r.visits)|sort|last|default(1) %}
                    <table class="w-full text-[13px]">
                        <thead>
                            <tr>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'URL'|trans({}, 'admin') }}</th>
                                <th class="uppercase text-content-secondary text-[11px] font-semibold">{{ 'Visits'|trans({}, 'admin') }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for referrer in rawReferrers %}
                                <tr>
                                    <td class="truncate" style="max-width: 300px;">
                                        <a href="{{ referrer.referrer }}" target="_blank" rel="noopener noreferrer" title="{{ referrer.referrer }}">
                                            {{ referrer.referrer|u.truncate(50, '...') }}
                                        </a>
                                    </td>
                                    <td class="text-content-secondary">{{ referrer.visits|number_format }}</td>
                                    <td class="w-25">
                                        <div class="h-1 w-full rounded-full bg-surface-raised overflow-hidden">
                                            <div class="h-full rounded-full bg-amber-500" style="width: {{ (referrer.visits / maxRefCount * 100)|round }}%"></div>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="3" class="text-content-secondary">{{ 'No data'|trans({}, 'admin') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
