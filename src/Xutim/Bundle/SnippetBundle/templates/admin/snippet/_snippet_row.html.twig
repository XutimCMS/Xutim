{% set activeTranslation = snippet.translationByLocale(activeLocale) %}

{% set refLocales = [default_locale] %}
{% for locale in visibleReferenceLocales|default([]) %}
    {% if locale != default_locale and locale != activeLocale %}
        {% set refLocales = refLocales|merge([locale]) %}
    {% endif %}
{% endfor %}

<div class="rounded-xl border border-border">
    <div class="border-b border-border px-4 py-3">
        <div class="flex items-center gap-2 flex-wrap">
            <twig:Xutim:Admin:Badge>{{ snippet.category.value }}</twig:Xutim:Admin:Badge>

            <a
                href="{{ admin_path('admin_snippet_edit', {id: snippet.id}) }}"
                data-turbo-frame="modal"
                class="font-bold no-underline"
            >{{ snippet.code }}</a>

            {% if snippet.description %}
                <span class="text-content-secondary">
                    &mdash; {{ snippet.description }}
                </span>
            {% endif %}
        </div>
    </div>

    <div class="p-4">
        {% if activeLocale != default_locale or refLocales|length > 1 %}
            {% for refLocale in refLocales %}
                {% if refLocale != activeLocale %}
                    {% set refTranslation = snippet.translationByLocale(refLocale) %}
                    <div class="mb-2 p-2 rounded-lg bg-surface-raised">
                        <div class="flex items-baseline gap-2">
                            <span class="inline-flex rounded border border-border px-1 py-0.5 text-[10px] font-medium text-content-secondary shrink-0">{{ refLocale|language_name|capitalize }}</span>
                            {% if refTranslation is not null %}
                                <span class="text-content-secondary text-wrap">{{ refTranslation.content }}</span>
                            {% else %}
                                <span class="text-content-secondary italic">{{ 'No translation'|trans({}, 'admin') }}</span>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        {% endif %}

        <div class="flex items-start gap-2">
            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium bg-blue-600 text-white mt-1">{{ activeLocale|upper }}</span>
            <textarea
                rows="2"
                class="form-control grow"
                data-snippet-editor-target="input"
                data-action="blur->snippet-editor#save"
                data-snippet-id="{{ snippet.id }}"
                data-locale="{{ activeLocale }}"
                data-token="{{ csrf_token('translate_snippet_' ~ snippet.id ~ '_' ~ activeLocale) }}"
                {{ canTranslateLocale ? '' : 'disabled' }}
            >{{ activeTranslation.content ?? '' }}</textarea>
        </div>
    </div>
</div>
