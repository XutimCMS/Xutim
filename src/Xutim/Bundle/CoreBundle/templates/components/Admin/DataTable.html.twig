<turbo-frame
    {{ attributes.defaults({}) }}
    id="{{ this.frameId }}-list"
    data-turbo-action="advance"
    class="{{ this.borderless ? 'flex flex-col flex-grow' : '' }}"
>
    {% set _formId = this.filterFormId ?: this.frameId ~ '-filters' %}
    {% set activeFilters = this.filter.cols %}

    {# Auto-promote per-column filters into toolbar filter buttons. #}
    {% set toolbarFilters = this.filters %}
    {% for column in this.columns %}
        {% set columnFilter = column.filter|default({type: 'none'}) %}
        {% if columnFilter.type|default('none') != 'none' %}
            {% set toolbarFilters = toolbarFilters|merge([{
                key: column.key,
                label: column.label,
                type: columnFilter.type,
                chipLabel: columnFilter.chipLabel|default(column.chipLabel|default(column.label)),
                options: columnFilter.options|default([]),
                placeholder: columnFilter.placeholder|default(null),
                minWidth: columnFilter.minWidth|default('220px'),
                formatter: columnFilter.formatter|default(null),
            }]) %}
        {% endif %}
    {% endfor %}

    {% set sortableColumns = this.columns|filter(c => c.sortable|default(false)) %}

    {% block filterChips %}
        {% if this.showChips %}
            {% set hasActiveFilters = false %}
            {% for f in toolbarFilters %}
                {% set v = activeFilters[f.key]|default('') %}
                {% if v is iterable %}{% set v = v|filter(x => x is not empty) %}{% endif %}
                {% if v is not empty %}{% set hasActiveFilters = true %}{% endif %}
            {% endfor %}

            {% if hasActiveFilters %}
                <div class="flex flex-wrap gap-1.5 items-center {{ this.borderless ? 'px-4 py-3 border-b border-border' : 'mb-3' }}">
                    <span class="text-[11px] text-content-tertiary">{{ 'Filters:'|trans({}, 'admin') }}</span>

                    {% for f in toolbarFilters %}
                        {% set v = activeFilters[f.key]|default('') %}
                        {% if v is iterable %}{% set v = v|filter(x => x is not empty) %}{% endif %}
                        {% if v is not empty %}
                            {% set displayValue = v %}
                            {% if (f.type == 'multiselect' or f.type == 'columnVisibility') and f.options is defined %}
                                {% set values = v is iterable ? v : [v] %}
                                {% set labels = [] %}
                                {% for val in values %}
                                    {% for opt in f.options|default([]) %}
                                        {% if not opt.separator|default(false) and (opt.value|default(opt)) == val %}
                                            {% set labels = labels|merge([opt.label|default(opt.value|default(opt))]) %}
                                        {% endif %}
                                    {% endfor %}
                                {% endfor %}
                                {% set displayValue = labels|join(', ') %}
                            {% elseif f.type == 'select' and f.options is defined %}
                                {% for opt in f.options|default([]) %}
                                    {% if not opt.separator|default(false) and (opt.value|default(opt)) == v %}
                                        {% set displayValue = opt.label|default(opt.value|default(opt)) %}
                                    {% endif %}
                                {% endfor %}
                            {% endif %}
                            {% if f.formatter == 'upper' %}{% set displayValue = displayValue|upper %}
                            {% elseif f.formatter == 'lower' %}{% set displayValue = displayValue|lower %}{% endif %}
                            {% set rest = activeFilters|filter((vv, k) => k != f.key) %}
                            {% set removeCol = rest|length > 0 ? rest : {_clear: '1'} %}
                            <a href="{{ admin_current_path_with({col: removeCol, page: 1}) }}" class="inline-flex items-center gap-1 rounded-md bg-accent-subtle border border-accent/20 px-2 py-0.5 text-[11px] font-medium text-accent hover:bg-accent/10 transition-colors">
                                {{ f.chipLabel }}: {{ displayValue }}
                                <twig:ux:icon name="ph:x" class="h-3 w-3" />
                            </a>
                        {% endif %}
                    {% endfor %}

                    <a href="{{ admin_current_path_with({col: {_clear: '1'}, page: 1}) }}" class="text-[11px] text-content-tertiary hover:text-content transition-colors">
                        {{ 'Clear all'|trans({}, 'admin') }}
                    </a>
                </div>
            {% endif %}
        {% endif %}
    {% endblock %}

    <form id="{{ _formId }}" method="get" action="">
        <input type="hidden" name="page" value="1">
        {% if filter.searchTerm %}<input type="hidden" name="searchTerm" value="{{ filter.searchTerm }}">{% endif %}
    </form>

    <div class="flex items-center flex-wrap gap-2 mb-3">
            <div data-turbo-permanent id="{{ this.frameId }}-search-container" class="relative flex-1 min-w-[180px] max-w-sm">
                <form method="GET" action="" data-controller="auto-submit">
                    {% for key, value in activeFilters %}
                        {% if value is iterable %}
                            {% for v in value %}<input type="hidden" name="col[{{ key }}][]" value="{{ v }}">{% endfor %}
                        {% else %}
                            <input type="hidden" name="col[{{ key }}]" value="{{ value }}">
                        {% endif %}
                    {% endfor %}
                    <twig:ux:icon name="ph:magnifying-glass" class="absolute left-2.5 top-1/2 -translate-y-1/2 h-3.5 w-3.5 text-content-tertiary pointer-events-none" />
                    <input type="text" id="{{ this.frameId }}-searchTerm" name="searchTerm"
                        class="w-full rounded-md border border-border bg-surface py-1.5 pl-8 pr-3 placeholder:text-content-tertiary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
                        aria-label="{{ 'search'|trans({}, 'admin')|capitalize }}"
                        value="{{ filter.searchTerm }}"
                        placeholder="{{ 'search'|trans({}, 'admin')|capitalize }}..."
                        data-action="auto-submit#debouncedSubmit"
                        onfocus="var t=this.value;this.value='';this.value=t" />
                </form>
            </div>

            {% block toolbarFilters %}
                {% for f in toolbarFilters %}
                    {% set selected = activeFilters[f.key]|default([]) %}
                    {% if selected is not iterable %}{% set selected = [selected] %}{% endif %}
                    {% set selected = selected|filter(v => v is not empty) %}
                    {% if selected is empty and f.defaultSelected is defined %}{% set selected = f.defaultSelected %}{% endif %}
                    {% set hasActive = selected|length > 0 %}
                    {% set buttonIcon = f.type == 'columnVisibility' ? 'ph:columns' : '' %}

                    <div class="relative" data-controller="dropdown">
                        <button type="button"
                            class="inline-flex items-center gap-1.5 rounded-md border px-2.5 py-1.5 font-medium transition-colors {{ hasActive ? 'border-accent bg-accent-subtle text-accent' : 'border-border text-content-secondary hover:border-border-strong hover:text-content' }}"
                            data-action="click->dropdown#toggle"
                        >
                            {% if buttonIcon %}<twig:ux:icon :name="buttonIcon" class="h-3.5 w-3.5" />{% endif %}
                            {{ f.label }}
                            {% if hasActive %}
                                <span class="flex h-4 min-w-[16px] items-center justify-center rounded-full bg-accent px-1 text-[10px] font-semibold text-white dark:text-black">{{ selected|length }}</span>
                            {% else %}
                                <twig:ux:icon name="ph:caret-down" class="h-3 w-3 text-content-tertiary" />
                            {% endif %}
                        </button>

                        <div data-dropdown-target="menu" class="hidden absolute left-0 top-full mt-1 z-50 rounded-lg border border-border bg-surface p-3 shadow-lg" style="min-width: {{ f.minWidth|default('220px') }}">
                            <label class="block font-medium text-content-secondary mb-2">
                                {{ 'Filter by %label%'|trans({'%label%': f.label}, 'admin') }}
                            </label>

                            {% if f.type == 'text' %}
                                <input type="text" class="w-full rounded-md border border-border bg-surface px-2.5 py-1.5 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent" name="col[{{ f.key }}]" value="{{ activeFilters[f.key]|default('') }}" placeholder="{{ f.placeholder|default('Type to search'|trans({}, 'admin')) }}" form="{{ _formId }}">
                            {% elseif f.type == 'select' %}
                                <select name="col[{{ f.key }}]" class="w-full rounded-md border border-border bg-surface px-2.5 py-1.5 focus:border-accent focus:outline-none" form="{{ _formId }}">
                                    <option value="">{{ f.placeholder|default('Any'|trans({}, 'admin')) }}</option>
                                    {% for opt in f.options|default([]) %}
                                        {% set ov = opt.value|default(opt) %}
                                        <option value="{{ ov }}" {{ activeFilters[f.key]|default('') == ov ? 'selected' }}>{{ opt.label|default(ov) }}</option>
                                    {% endfor %}
                                </select>
                            {% elseif f.type == 'multiselect' or f.type == 'columnVisibility' %}
                                <div class="flex flex-col gap-2 max-h-[240px] overflow-y-auto">
                                    {% for opt in f.options|default([]) %}
                                        {% if opt.separator|default(false) %}
                                            <hr class="border-border my-1">
                                        {% else %}
                                            {% set ov = opt.value|default(opt) %}
                                            <label class="flex items-center gap-2 cursor-pointer">
                                                <input type="checkbox" class="h-4 w-4 rounded border-border text-accent focus:ring-accent" name="col[{{ f.key }}][]" value="{{ ov }}" form="{{ _formId }}" {{ ov in selected ? 'checked' }}>
                                                <span>{{ opt.label|default(ov) }}</span>
                                            </label>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            {% endif %}

                            <div class="mt-3 flex justify-end">
                                <button type="submit" class="rounded-md bg-accent px-2.5 py-1 font-medium text-white hover:bg-accent-hover dark:text-black transition-colors" form="{{ _formId }}">
                                    {{ 'Apply'|trans({}, 'admin') }}
                                </button>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            {% endblock %}

            {% if sortableColumns|length > 0 %}
                {% block sortDropdown %}
                    <div class="relative ml-auto" data-controller="dropdown" data-dropdown-placement-value="bottom-end">
                        <button type="button"
                            class="inline-flex items-center gap-1.5 rounded-md border border-border px-2.5 py-1.5 font-medium text-content-secondary hover:border-border-strong hover:text-content transition-colors"
                            data-action="click->dropdown#toggle"
                        >
                            <twig:ux:icon name="ph:arrows-down-up" class="h-3.5 w-3.5" />
                            {{ 'Sort'|trans({}, 'admin') }}
                        </button>

                        <div data-dropdown-target="menu" class="hidden absolute right-0 top-full mt-1 z-50 min-w-[200px] rounded-lg border border-border bg-surface shadow-lg py-1">
                            {% for column in sortableColumns %}
                                {% set orderKey = column.order|default(column.key) %}
                                {% set isAscActive = this.filter.orderColumn == orderKey and this.filter.orderDirection|lower == 'asc' %}
                                {% set isDescActive = this.filter.orderColumn == orderKey and this.filter.orderDirection|lower == 'desc' %}

                                <a href="{{ admin_current_path_with({orderColumn: orderKey, orderDirection: 'asc'}) }}" class="flex w-full items-center gap-2 px-3 py-1.5 hover:bg-surface-raised transition-colors {{ isAscActive ? 'text-accent font-medium' : 'text-content-secondary' }}">
                                    {% if isAscActive %}<twig:ux:icon name="ph:check" class="h-3 w-3" />{% else %}<span class="w-3"></span>{% endif %}
                                    {{ column.label }} <twig:ux:icon name="ph:arrow-up" class="h-3 w-3 text-content-tertiary" />
                                </a>
                                <a href="{{ admin_current_path_with({orderColumn: orderKey, orderDirection: 'desc'}) }}" class="flex w-full items-center gap-2 px-3 py-1.5 hover:bg-surface-raised transition-colors {{ isDescActive ? 'text-accent font-medium' : 'text-content-secondary' }}">
                                    {% if isDescActive %}<twig:ux:icon name="ph:check" class="h-3 w-3" />{% else %}<span class="w-3"></span>{% endif %}
                                    {{ column.label }} <twig:ux:icon name="ph:arrow-down" class="h-3 w-3 text-content-tertiary" />
                                </a>
                                {% if not loop.last %}<div class="border-t border-border my-1"></div>{% endif %}
                            {% endfor %}
                        </div>
                    </div>
                {% endblock %}
            {% endif %}
    </div>

    <div class="rounded-xl border border-border {{ this.borderless ? 'border-0 shadow-none flex flex-col flex-grow' : '' }}">
        <div class="{{ this.responsive ? 'overflow-x-auto' : '' }}{{ this.borderless ? ' overflow-auto' : '' }}">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-border bg-surface-raised text-left">
                        {% for column in this.columns %}
                            {% if column.headerVisible|default(true) %}
                                <th class="px-4 py-2.5 font-medium text-content-tertiary whitespace-nowrap {{ column.headerClass|default('') }}">
                                    {{ column.label }}
                                </th>
                            {% endif %}
                        {% endfor %}
                    </tr>
                </thead>
                <tbody class="divide-y divide-border" {% if this.tableBodyId is defined %}id="{{ this.tableBodyId }}"{% endif %} data-table-target="tableBody">
                    {% block body %}{% endblock %}
                </tbody>
            </table>
        </div>

        {% if pager.nbPages > 0 %}
            <div class="flex items-center justify-between border-t border-border px-4 py-2.5 {{ this.borderless ? 'mt-auto' : '' }}">
                <span class="text-content-secondary">
                    {{ 'page'|trans({}, 'admin')|capitalize }} {{ pager.currentPage }} {{ 'of'|trans({}, 'admin') }} {{ pager.nbPages }}
                    ({{ pager.count }} {{ 'entries'|trans({}, 'admin') }})
                </span>
                <div class="flex items-center gap-1">
                    {% set currentPage = pager.currentPage %}
                    {% set lastPage = pager.nbPages %}
                    {% set pageWindow = 1 %}
                    {% set windowStart = max(2, currentPage - pageWindow) %}
                    {% set windowEnd = min(lastPage - 1, currentPage + pageWindow) %}

                    {% if pager.hasPreviousPage %}
                        <a href="{{ pagerfanta_page_url(pager, pager.previousPage) }}" class="inline-flex items-center gap-1 rounded-md px-2.5 py-1 text-content-secondary hover:bg-surface-raised transition-colors">
                            <twig:ux:icon name="ph:caret-left" class="h-3 w-3" /> {{ 'prev'|trans({}, 'admin') }}
                        </a>
                    {% else %}
                        <span class="inline-flex items-center gap-1 rounded-md px-2.5 py-1 text-content-tertiary">
                            <twig:ux:icon name="ph:caret-left" class="h-3 w-3" /> {{ 'prev'|trans({}, 'admin') }}
                        </span>
                    {% endif %}

                    {% if lastPage >= 1 %}
                        {% if currentPage == 1 %}
                            <span class="inline-flex items-center justify-center min-w-[28px] rounded-md bg-accent px-2.5 py-1 font-medium text-white dark:text-black">1</span>
                        {% else %}
                            <a href="{{ pagerfanta_page_url(pager, 1) }}" class="inline-flex items-center justify-center min-w-[28px] rounded-md px-2.5 py-1 text-content-secondary hover:bg-surface-raised transition-colors">1</a>
                        {% endif %}
                    {% endif %}

                    {% if windowStart > 2 %}
                        <span class="px-1 text-content-tertiary">…</span>
                    {% endif %}

                    {% if windowStart <= windowEnd %}
                        {% for p in windowStart..windowEnd %}
                            {% if p == currentPage %}
                                <span class="inline-flex items-center justify-center min-w-[28px] rounded-md bg-accent px-2.5 py-1 font-medium text-white dark:text-black">{{ p }}</span>
                            {% else %}
                                <a href="{{ pagerfanta_page_url(pager, p) }}" class="inline-flex items-center justify-center min-w-[28px] rounded-md px-2.5 py-1 text-content-secondary hover:bg-surface-raised transition-colors">{{ p }}</a>
                            {% endif %}
                        {% endfor %}
                    {% endif %}

                    {% if windowEnd < lastPage - 1 %}
                        <span class="px-1 text-content-tertiary">…</span>
                    {% endif %}

                    {% if lastPage > 1 %}
                        {% if currentPage == lastPage %}
                            <span class="inline-flex items-center justify-center min-w-[28px] rounded-md bg-accent px-2.5 py-1 font-medium text-white dark:text-black">{{ lastPage }}</span>
                        {% else %}
                            <a href="{{ pagerfanta_page_url(pager, lastPage) }}" class="inline-flex items-center justify-center min-w-[28px] rounded-md px-2.5 py-1 text-content-secondary hover:bg-surface-raised transition-colors">{{ lastPage }}</a>
                        {% endif %}
                    {% endif %}

                    {% if pager.hasNextPage %}
                        <a href="{{ pagerfanta_page_url(pager, pager.nextPage) }}" class="inline-flex items-center gap-1 rounded-md px-2.5 py-1 text-content-secondary hover:bg-surface-raised transition-colors">
                            {{ 'next'|trans({}, 'admin') }} <twig:ux:icon name="ph:caret-right" class="h-3 w-3" />
                        </a>
                    {% else %}
                        <span class="inline-flex items-center gap-1 rounded-md px-2.5 py-1 text-content-tertiary">
                            {{ 'next'|trans({}, 'admin') }} <twig:ux:icon name="ph:caret-right" class="h-3 w-3" />
                        </span>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    </div>
</turbo-frame>
