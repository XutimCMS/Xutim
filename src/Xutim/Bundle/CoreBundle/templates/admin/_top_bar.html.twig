<header id="navbar-main" class="navbar navbar-expand-md d-print-none">
    <div class="container-xl">
        <twig:Xutim:Admin:Button
            variant="default"
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbar-menu"
            aria-controls="navbar-menu"
            aria-expanded="false"
            aria-label="Toggle navigation"
        >
            <span class="navbar-toggler-icon"></span>
        </twig:Xutim:Admin:Button>

        <div class="navbar-nav flex-row order-md-last">
            <div class="flex align-items-center mr-2">
                    {{ publicLinkBlock|raw }}
                    <a href="{{ admin_path('admin_article_list', {searchTerm: ''}) }}" class="nav-link px-2" title="Search">
                        <twig:ux:icon name="ph:magnifying-glass" class="h-4 w-4 shrink-0"/>
                    </a>
                    <a href="{{ admin_path('admin_notification_list') }}" class="nav-link px-2 flex align-items-center" title="Notifications">
                        <twig:ux:icon name="ph:bell" class="h-4 w-4 shrink-0"/>
                        {% if notification_center.unreadCount > 0 %}
                            <span class="badge bg-danger text-white ml-1" style="font-size: .6rem; min-width: .9rem; height: .9rem; padding: 0; line-height: .9rem; border-radius: 50%;">
                                {{ notification_center.unreadCount > 99 ? '99+' : notification_center.unreadCount }}
                            </span>
                        {% endif %}
                    </a>
            </div>
            <twig:Xutim:Admin:Dropdown placement="bottom-end">
                <twig:block name="trigger">
                    <twig:Xutim:Admin:Button
                        tag="button"
                        variant="ghost"
                        class="!p-0"
                        data-action="click->dropdown#toggle"
                        aria-label="Open user menu"
                    >
                        <span
                            class="h-7 w-7 rounded-full bg-cover bg-center shrink-0"
                            style="background-image: url({{ app.user.avatar }})"
                        ></span>
                        <div class="hidden xl:block pl-2 text-left">
                            <div class="font-medium">{{ app.user.name }}</div>
                            <div class="mt-0.5 text-[11px] text-content-tertiary">
                                {{ app.user.userIdentifier }}
                            </div>
                        </div>
                    </twig:Xutim:Admin:Button>
                </twig:block>
                <twig:block name="content">
                    <twig:Xutim:Admin:Button tag="a" variant="dropdown" href="{{ admin_path('admin_user_profile') }}">
                        Profile
                    </twig:Xutim:Admin:Button>
                    <div class="my-1 border-t border-border"></div>
                    <twig:Xutim:Admin:Button tag="a" variant="dropdown" href="{{ admin_path('admin_logout') }}">
                        <twig:ux:icon name="ph:sign-out" class="h-4 w-4 shrink-0" />
                        Logout
                    </twig:Xutim:Admin:Button>
                </twig:block>
            </twig:Xutim:Admin:Dropdown>
        </div>

        <div class="navbar-collapse collapse" id="navbar-menu">
            <ul class="navbar-nav">
                <li
                    class="nav-item{{ app.current_route == 'admin_homepage' ? ' active' : '' }}"
                >
                    <a class="nav-link" href="{{ admin_path('admin_homepage') }}">
                        <span class="nav-link-icon md:hidden d-lg-inline-block">
                            <twig:ux:icon name="ph:house" class="h-4 w-4 shrink-0" />
                        </span>
                        <span class="nav-link-title">
                            {{ 'dashboard'|trans({}, 'admin')|capitalize }}
                        </span>
                    </a>
                </li>
                <li
                    class="nav-item{{ app.current_route starts with 'admin_page' ? ' active' : '' }}"
                >
                    <a class="nav-link" href="{{ admin_path('admin_page_list') }}">
                        <span class="nav-link-icon md:hidden d-lg-inline-block">
                            <twig:ux:icon name="ph:folder-simple" class="h-4 w-4 shrink-0" />
                        </span>
                        <span class="nav-link-title">
                            {{ 'pages'|trans({}, 'admin')|capitalize }}
                        </span>
                    </a>
                </li>
                <li
                    class="nav-item{{ app.current_route starts with 'admin_article' ? ' active' : '' }}"
                >
                    <a
                        class="nav-link"
                        href="{{ admin_path('admin_article_list', {searchTerm: ''}) }}"
                    >
                        <span class="nav-link-icon md:hidden d-lg-inline-block">
                            <twig:ux:icon name="ph:newspaper" class="h-4 w-4 shrink-0" />
                        </span>
                        <span class="nav-link-title">
                            {{ 'articles'|trans({}, 'admin')|capitalize }}
                        </span>
                    </a>
                </li>

                <li
                    class="nav-item{{ app.current_route starts with 'admin_tag' ? ' active' : '' }}"
                >
                    <a
                        class="nav-link"
                        href="{{ admin_path('admin_tag_list', {searchTerm: ''}) }}"
                    >
                        <span class="nav-link-icon md:hidden d-lg-inline-block">
                            <twig:ux:icon name="ph:tag" class="h-4 w-4 shrink-0" />
                        </span>
                        <span class="nav-link-title">
                            {{ 'tags'|trans({}, 'admin')|capitalize }}
                        </span>
                    </a>
                </li>

                <li
                    class="nav-item{{ app.current_route starts with 'admin_snippet' ? ' active' : '' }}"
                >
                    <a
                        class="nav-link"
                        href="{{ admin_path('admin_snippet_list', {searchTerm: ''}) }}"
                    >
                        <span class="nav-link-icon md:hidden d-lg-inline-block">
                            <twig:ux:icon name="ph:text-aa" class="h-4 w-4 shrink-0" />
                        </span>
                        <span class="nav-link-title">
                            {{ 'snippets'|trans({}, 'admin')|capitalize }}
                        </span>
                    </a>
                </li>

                <li
                    class="nav-item{{ app.current_route starts with 'admin_media' ? ' active' : '' }}"
                >
                    <a
                        class="nav-link"
                        href="{{ admin_path('admin_media_list', {searchTerm: ''}) }}"
                    >
                        <span class="nav-link-icon md:hidden d-lg-inline-block">
                            <twig:ux:icon name="ph:image" class="h-4 w-4 shrink-0" />
                        </span>
                        <span class="nav-link-title">
                            {{ 'media'|trans({}, 'admin')|capitalize }}
                        </span>
                    </a>
                </li>

                {% if is_granted(constant('Xutim\\SecurityBundle\\Security\\UserRoles::ROLE_EDITOR')) %}
                    <li
                        class="nav-item{{ app.current_route starts with 'admin_block' ? ' active' : '' }}"
                    >
                        <a
                            class="nav-link"
                            href="{{ admin_path('admin_block_list', {searchTerm: ''}) }}"
                        >
                            <span
                                class="nav-link-icon md:hidden d-lg-inline-block"
                            >
                                <twig:ux:icon name="ph:squares-four" class="h-4 w-4 shrink-0" />
                            </span>
                            <span class="nav-link-title">
                                {{ 'blocks'|trans({}, 'admin')|capitalize }}
                            </span>
                        </a>
                    </li>
                {% endif %}

                {% if is_granted(constant('Xutim\\SecurityBundle\\Security\\UserRoles::ROLE_DEVELOPER')) %}
                    <li
                        class="nav-item{{ app.current_route starts with 'admin_settings_' ? ' active' : '' }}"
                    >
                        <a
                            class="nav-link"
                            href="{{ admin_path('admin_settings_site') }}"
                        >
                            <span
                                class="nav-link-icon md:hidden d-lg-inline-block"
                            >
                                <twig:ux:icon name="ph:gear" class="h-4 w-4 shrink-0" />
                            </span>
                            <span class="nav-link-title">
                                {{ 'settings'|trans({}, 'admin')|capitalize }}
                            </span>
                        </a>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>
</header>
