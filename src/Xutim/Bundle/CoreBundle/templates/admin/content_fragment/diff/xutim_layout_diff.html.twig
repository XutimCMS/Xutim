<div class="xutim-layout-diff">
    <div class="text-[12px] text-content-tertiary mb-2 flex items-center gap-2">
        <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium bg-purple-50 text-purple-700 dark:bg-purple-500/10 dark:text-purple-400">xutimLayout</span>
        {% if row.layout_code_changed %}
            <del class="text-red-600 dark:text-red-400">{{ row.old_layout_code }}</del>
            <span>→</span>
            <ins class="text-green-600 dark:text-green-400 no-underline">{{ row.layout_code }}</ins>
        {% else %}
            <code class="text-[12px]">{{ row.layout_code }}</code>
        {% endif %}
    </div>

    <dl class="grid grid-cols-12 gap-x-3 gap-y-2">
        {% for fieldName in row.fields %}
            {% set fieldMeta = row.meta[fieldName] ?? null %}
            {% set fieldPart = row.parts[fieldName] ?? null %}
            {% set fieldStatus = fieldMeta.status ?? 'same' %}

            <dt class="col-span-3 truncate text-[12px] font-semibold">
                {{ fieldName }}
                {% if fieldStatus == 'changed' %}
                    <span class="ml-1 inline-flex items-center rounded-full px-1.5 py-0.5 text-[10px] font-medium bg-amber-50 text-amber-700 dark:bg-amber-500/10 dark:text-amber-400">{{ 'changed'|trans({}, 'admin') }}</span>
                {% endif %}
            </dt>
            <dd class="col-span-9">
                {% if fieldPart is not null and fieldPart.kind == 'text' %}
                    <div class="diff-inline">{{ fieldPart.html|raw }}</div>
                {% elseif fieldPart is not null and fieldPart.kind == 'ref' %}
                    {% if fieldStatus == 'changed' %}
                        <del class="text-red-600 dark:text-red-400">{{ fieldMeta.old|default('') }}</del>
                        <span>→</span>
                        <ins class="text-green-600 dark:text-green-400 no-underline">{{ fieldMeta.new|default('') }}</ins>
                    {% else %}
                        <code class="text-[12px]">{{ fieldPart.html|raw }}</code>
                    {% endif %}
                {% endif %}
            </dd>
        {% endfor %}
    </dl>
</div>
