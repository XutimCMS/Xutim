{% set currentUrl = row.attrs.thumbnailUrl ?? row.attrs.url ?? row.data.file.thumbnailUrl ?? row.data.file.url ?? '' %}
{% set urlMeta = meta is defined and meta.thumbnailUrl is defined and meta.thumbnailUrl.new ? meta.thumbnailUrl : (meta is defined and meta.url is defined ? meta.url : null) %}
{% set changed = urlMeta and urlMeta.status is defined and urlMeta.status != 'same' %}

{% macro image_row(label, url) %}
    <div class="flex items-center gap-2 flex-wrap mb-2">
        <div class="text-sm text-content-secondary mr-2" style="width: 3rem">{{ label }}</div>
        {% if url %}
            <img
                src="{{ url }}"
                alt=""
                class="border border-border rounded"
                style="max-width: 120px; height: auto"
            >
        {% else %}
            <div class="text-sm text-content-secondary">&mdash;</div>
        {% endif %}
    </div>
{% endmacro %}

{% import _self as I %}

{% if op == 'added' or op == 'removed' or meta is not defined or meta is empty %}
    {{ I.image_row('', currentUrl) }}
{% elseif changed %}
    {% set oldUrl = urlMeta.old ?? '' %}
    {% set newUrl = urlMeta.new ?? currentUrl %}
    {{ I.image_row('Old', oldUrl) }}
    <div class="text-content-secondary my-1">&rarr;</div>
    {{ I.image_row('New', newUrl) }}
{% else %}
    {{ I.image_row('', currentUrl) }}
{% endif %}
