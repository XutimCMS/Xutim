<div class="reference-diff">
    <div class="text-sm text-content-secondary mb-3">
        {{ 'Comparing reference at'|trans({}, 'admin') }}
        <strong>{{ oldRevision.recordedAt|date('d M Y H:i') }}</strong>
        {{ 'with current version'|trans({}, 'admin') }}
    </div>

    <div class="mb-3">
        <label class="text-sm font-bold text-content">{{ 'Intro title'|trans({}, 'admin') }}</label>
        <div class="p-2 bg-surface-raised rounded">{{ preTitleDiff|raw }}</div>
    </div>

    <div class="mb-3">
        <label class="text-sm font-bold text-content">{{ 'Title'|trans({}, 'admin') }}</label>
        <div class="p-2 bg-surface-raised rounded">{{ titleDiff|raw }}</div>
    </div>

    <div class="mb-3">
        <label class="text-sm font-bold text-content">{{ 'Subtitle'|trans({}, 'admin') }}</label>
        <div class="p-2 bg-surface-raised rounded">{{ subTitleDiff|raw }}</div>
    </div>

    <div class="mb-3">
        <label class="text-sm font-bold text-content">{{ 'Description'|trans({}, 'admin') }}</label>
        <div class="p-2 bg-surface-raised rounded">{{ descriptionDiff|raw }}</div>
    </div>

    <div class="mb-3">
        <label class="text-sm font-bold text-content">{{ 'Content'|trans({}, 'admin') }}</label>
        <div class="mt-2">
            {{ include('@XutimCore/admin/content_fragment/content_diff.html.twig', {rows: contentRows, locale: content_context_language()}) }}
        </div>
    </div>
</div>
