{% extends '@XutimCore/admin/article/article_edit.html.twig' %}

{% block pageMenu %}
    <twig:Xutim:Admin:Button
        tag="a"
        variant="nav"
        href="{{ admin_path('admin_article_edit', {id: article.id}) }}"
    >
        <twig:ux:icon name="ph:pencil-simple" class="icon mr-1" />
        {{ 'Edit'|trans({}, 'admin') }}
    </twig:Xutim:Admin:Button>

    <twig:Xutim:Admin:Button
        tag="a"
        variant="nav"
        href="{{ admin_path('admin_article_show', {id: article.id}) }}"
    >
        <twig:ux:icon name="ph:magnifying-glass" class="icon mr-1" />
        {{ 'Show'|trans({}, 'admin') }}
    </twig:Xutim:Admin:Button>

    <twig:Xutim:Admin:Button
        tag="button"
        onclick="window.dispatchEvent(new Event('sidebar:toggle'))"
        variant="nav"
    >
        <twig:ux:icon name="ph:sidebar-simple" class="icon mr-1" />
        {{ 'Sidebar'|trans({}, 'admin') }}
    </twig:Xutim:Admin:Button>
{% endblock %}

{% block body %}
    {{ include('@XutimCore/admin/revision/_revision_content.html.twig') }}
{% endblock %}
