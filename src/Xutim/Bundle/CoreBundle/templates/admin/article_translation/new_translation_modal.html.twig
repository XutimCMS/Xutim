<div
    data-turbo-allow-cache="true"
    data-controller="plain-modal"
>
    <form id="form" name="form" method="post">
        <div class="p-5">
            <div class="flex justify-center mb-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-amber-50 dark:bg-amber-500/10">
                    <twig:ux:icon name="ph:warning" class="h-5 w-5 text-amber-600 dark:text-amber-400" />
                </div>
            </div>

            <h3 class="text-[15px] font-semibold mb-2">
                {{
                    'This page does not exist in %language%. Do you want to copy content from another language?'|trans({'%language%': content_context_language()|language_name}, 'admin')
                }}
            </h3>

            <div class="mb-3">
                <label class="block text-[12px] font-medium text-content-secondary mb-1" for="form_locale">
                    {{ 'choose language'|trans({}, 'admin')|capitalize }}
                </label>
                <select
                    name="form[locale]"
                    id="form_locale"
                    class="w-full rounded-lg border border-border bg-surface px-3 py-2 text-[13px] focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
                    data-plain-modal-target="localeSelect"
                >
                    {% set defaultTrans = article.getDefaultTranslation() %}
                    {% for trans in article.translations|sort((a, b) => a.locale|language_name <=> b.locale|language_name) %}
                        <option
                            value="{{ trans.locale }}"
                            data-url-value="{{ admin_path('admin_article_edit', {id: article.id, locale: trans.locale}) }}"
                            {% if trans.id == defaultTrans.id %}selected{% endif %}
                        >
                            {{ trans.locale|language_name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
        </div>

        <div class="flex items-center gap-3 border-t border-border px-5 py-3">
            <twig:Xutim:Admin:Button
                variant="secondary"
                type="button"
                class="flex-1"
                data-action="click->plain-modal#dismissModal"
            >
                {{ 'action.close'|trans({}, 'admin')|capitalize }}
            </twig:Xutim:Admin:Button>
            <div class="flex-1">
                <input
                    id="form__token"
                    name="form[_token]"
                    value="{{ csrf_token('xutim-dialog') }}"
                    type="hidden"
                />
                <twig:Xutim:Admin:Button
                    variant="primary"
                    type="button"
                    data-action="click->plain-modal#getResponse"
                    class="w-full"
                >
                    {{ 'action.copy'|trans({}, 'admin')|capitalize }}
                </twig:Xutim:Admin:Button>
            </div>
        </div>
    </form>
</div>
