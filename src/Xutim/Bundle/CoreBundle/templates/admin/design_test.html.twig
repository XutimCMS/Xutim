<script>
function toggleSidebar() {
    const sidebar = document.getElementById('sidebar');
    const backdrop = document.getElementById('sidebar-backdrop');
    const isOpen = !sidebar.classList.contains('-translate-x-full');
    sidebar.classList.toggle('-translate-x-full');
    backdrop.classList.toggle('hidden');
}

function toggleDark() {
    document.documentElement.classList.toggle('dark');
    const isDark = document.documentElement.classList.contains('dark');
    document.getElementById('icon-sun').classList.toggle('hidden', !isDark);
    document.getElementById('icon-moon').classList.toggle('hidden', isDark);
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
}

function showView(name) {
    document.querySelectorAll('.view').forEach(v => { v.classList.add('hidden'); });
    const el = document.getElementById('view-' + name);
    if (el) { el.classList.remove('hidden'); }
    window.scrollTo(0, 0);
    // Destroy EditorJS when leaving components to prevent floating elements
    if (name !== 'components' && editorInstance) {
        editorInstance.destroy(); editorInstance = null;
    }

    // Show/hide article sidebar based on view
    const sidebar = document.getElementById('article-sidebar');
    if (name === 'article-edit') {
        initArticleSidebar();
    } else {
        sidebar.classList.add('translate-x-full');
        sidebar.dataset.open = 'false';
        document.body.classList.remove('article-sidebar-open');
        document.getElementById('article-sidebar-backdrop').classList.add('hidden');
        document.getElementById('article-sidebar-edge-tab').classList.add('hidden');
        document.getElementById('article-sidebar-collapse-tab').classList.add('hidden');
    }

    // For articles, clicking an article row shows the edit view
    if (name === 'articles') {
        document.getElementById('view-articles').querySelectorAll('tbody tr').forEach(row => {
            row.onclick = () => showView('article-edit');
        });
    }

    // Update nav highlight
    document.querySelectorAll('.nav-link').forEach(l => {
        l.classList.remove('bg-accent-subtle', 'text-accent');
        l.classList.add('text-content-secondary');
    });
    const active = document.querySelector(`[data-nav="${name}"]`);
    if (active) {
        active.classList.add('bg-accent-subtle', 'text-accent');
        active.classList.remove('text-content-secondary');
    }

    // Update breadcrumb
    const labels = {dashboard: 'Dashboard', articles: 'Articles', 'article-edit': 'Articles > Edit', pages: 'Pages', settings: 'Settings', media: 'Media', notifications: 'Notifications', analytics: 'Analytics', components: 'Components'};
    if (name === 'components') { setTimeout(initEditor, 100); }
    document.getElementById('breadcrumb').innerHTML = '<span>' + (labels[name] || name) + '</span>';
}

if (localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
    document.documentElement.classList.add('dark');
    document.getElementById('icon-sun').classList.remove('hidden');
    document.getElementById('icon-moon').classList.add('hidden');
}

// Article sidebar toggle
function toggleArticleSidebar() {
    const sidebar = document.getElementById('article-sidebar');
    const backdrop = document.getElementById('article-sidebar-backdrop');
    const openTab = document.getElementById('article-sidebar-edge-tab');
    const closeTab = document.getElementById('article-sidebar-collapse-tab');
    const isOpen = sidebar.dataset.open === 'true';

    if (isOpen) {
        sidebar.classList.add('translate-x-full');
        sidebar.dataset.open = 'false';
        backdrop.classList.add('hidden');
        document.body.classList.remove('article-sidebar-open');
        openTab.classList.remove('hidden');
        closeTab.classList.add('hidden');
    } else {
        sidebar.classList.remove('translate-x-full');
        sidebar.dataset.open = 'true';
        document.body.classList.add('article-sidebar-open');
        openTab.classList.add('hidden');
        closeTab.classList.remove('hidden');
        if (window.innerWidth < 1280) {
            backdrop.classList.remove('hidden');
        }
    }
}

function initArticleSidebar() {
    const openTab = document.getElementById('article-sidebar-edge-tab');
    const closeTab = document.getElementById('article-sidebar-collapse-tab');
    if (window.innerWidth >= 1280) {
        const sidebar = document.getElementById('article-sidebar');
        sidebar.classList.remove('translate-x-full');
        sidebar.dataset.open = 'true';
        document.body.classList.add('article-sidebar-open');
        openTab.classList.add('hidden');
        closeTab.classList.remove('hidden');
    } else {
        openTab.classList.remove('hidden');
        closeTab.classList.add('hidden');
    }
}

// Language bar helpers
function selectLang(btn) {
    // Visual feedback only for demo
    const container = btn.closest('.flex');
    if (!container) return;
    container.querySelectorAll('.lang-btn').forEach(b => {
        b.classList.remove('border-accent', 'bg-accent', 'text-white', 'dark:text-black', 'bg-accent-subtle', 'ring-1', 'ring-accent/20');
        b.classList.add('border-border', 'text-content-secondary');
    });
    btn.classList.remove('border-border', 'text-content-secondary');
    btn.classList.add('border-accent', 'bg-accent', 'text-white', 'dark:text-black');
}

function filterLangs(input) {
    const query = input.value.toLowerCase();
    const grid = input.closest('.hidden, div')?.parentElement?.querySelector('.grid') || input.closest('div').nextElementSibling;
    if (!grid) return;
    grid.querySelectorAll('.lang-option').forEach(btn => {
        const lang = (btn.dataset.lang || btn.textContent).toLowerCase().trim();
        btn.style.display = lang.includes(query) ? '' : 'none';
    });
}

// Close all dropdowns on outside click
document.addEventListener('click', (e) => {
    if (!e.target.closest('.relative')) {
        document.querySelectorAll('.lang-more-btn + div, .filter-trigger + div').forEach(d => d.classList.add('hidden'));
    }
});

// Filter apply (demo)
const activeFilters = {};
function applyFilter(btn, filterId, value) {
    const dropdown = btn.closest('.relative').querySelector('.filter-trigger + div');
    dropdown.classList.add('hidden');

    // Update checkmark
    dropdown.querySelectorAll('button').forEach(b => {
        b.classList.remove('text-accent', 'font-medium');
        b.classList.add('text-content-secondary');
        const icon = b.querySelector('i.ph');
        if (icon) icon.parentElement.replaceChild(Object.assign(document.createElement('span'), {className: 'w-3.5'}), icon);
    });
    const check = document.createElement('i');
    check.className = 'ph ph-check text-xs';
    btn.querySelector('span.w-3\\.5, i.ph')?.replaceWith(check);
    btn.classList.add('text-accent', 'font-medium');
    btn.classList.remove('text-content-secondary');

    // Update trigger style
    const trigger = btn.closest('.relative').querySelector('.filter-trigger');
    const isDefault = btn === dropdown.querySelector('button:first-child');
    if (isDefault) {
        delete activeFilters[filterId];
        trigger.classList.remove('border-accent', 'bg-accent-subtle', 'text-accent');
        trigger.classList.add('border-border', 'text-content-secondary');
    } else {
        activeFilters[filterId] = value;
        trigger.classList.add('border-accent', 'bg-accent-subtle', 'text-accent');
        trigger.classList.remove('border-border', 'text-content-secondary');
    }

    // Update active filters row
    const container = document.getElementById('active-filters');
    const chips = container.querySelectorAll('.filter-chip');
    chips.forEach(c => c.remove());

    const keys = Object.keys(activeFilters);
    if (keys.length > 0) {
        container.classList.remove('hidden');
        keys.forEach(k => {
            const chip = document.createElement('button');
            chip.className = 'filter-chip inline-flex items-center gap-1 rounded-md bg-accent-subtle border border-accent/20 px-2 py-0.5 text-[11px] font-medium text-accent hover:bg-accent/10 transition-colors';
            chip.innerHTML = k + ': ' + activeFilters[k] + ' <i class="ph ph-x text-xs"></i>';
            chip.onclick = () => {
                const trigger = document.querySelector('[onclick*="' + k + '"]')?.closest('.relative')?.querySelector('.filter-trigger + div button:first-child');
                if (trigger) applyFilter(trigger, k, 'All');
            };
            container.appendChild(chip);
        });
    } else {
        container.classList.add('hidden');
    }
}

// Toast notifications
function showToast(type, title, message) {
    const container = document.getElementById('toast-container');
    const colors = {
        success: 'border-green-500/30 bg-green-50 dark:bg-green-500/10',
        error: 'border-red-500/30 bg-red-50 dark:bg-red-500/10',
        warning: 'border-amber-500/30 bg-amber-50 dark:bg-amber-500/10',
        info: 'border-border bg-surface'
    };
    const icons = {
        success: 'ph-check-circle text-green-600 dark:text-green-400',
        error: 'ph-x-circle text-red-600 dark:text-red-400',
        warning: 'ph-warning text-amber-600 dark:text-amber-400',
        info: 'ph-info text-blue-600 dark:text-blue-400'
    };
    const toast = document.createElement('div');
    toast.className = `pointer-events-auto flex items-start gap-3 rounded-lg border ${colors[type]} p-3 shadow-lg animate-slide-in`;
    toast.innerHTML = `
        <i class="ph ${icons[type]} text-lg shrink-0 mt-0.5"></i>
        <div class="flex-1 min-w-0">
            <p class="text-[13px] font-medium">${title}</p>
            <p class="text-[12px] text-content-secondary mt-0.5">${message}</p>
        </div>
        <button onclick="this.parentElement.remove()" class="shrink-0 rounded-md p-0.5 hover:bg-black/5 dark:hover:bg-white/5">
            <i class="ph ph-x text-xs text-content-tertiary"></i>
        </button>
    `;
    container.appendChild(toast);
    setTimeout(() => { toast.style.opacity = '0'; toast.style.transform = 'translateX(100%)'; toast.style.transition = 'all 0.3s'; setTimeout(() => toast.remove(), 300); }, 4000);
}

// Modals
function openModal(id) {
    const modal = document.getElementById(id);
    modal.classList.remove('hidden');
    modal.classList.add('flex');
}
function closeModal(id) {
    const modal = document.getElementById(id);
    modal.classList.add('hidden');
    modal.classList.remove('flex');
}

// Impersonation bar
function toggleImpersonation() {
    const bar = document.getElementById('impersonation-bar');
    const wrapper = document.getElementById('main-wrapper');
    const sidebar = document.getElementById('sidebar');
    if (bar.classList.contains('hidden')) {
        bar.classList.remove('hidden');
        wrapper.style.paddingTop = '2.25rem';
        sidebar.style.paddingTop = '2.25rem';
    } else {
        bar.classList.add('hidden');
        wrapper.style.paddingTop = '';
        sidebar.style.paddingTop = '';
    }
}

// EditorJS init
let editorInstance = null;
function initEditor() {
    if (editorInstance) return;
    const holder = document.getElementById('editorjs');
    if (!holder || holder.offsetParent === null) return;
    editorInstance = new EditorJS({
        holder: 'editorjs',
        tools: {
            header: { class: window.Header, config: { levels: [2, 3, 4], defaultLevel: 2 } },
            list: { class: window.EditorjsList || window.List, inlineToolbar: true },
            quote: { class: window.Quote, inlineToolbar: true },
            code: window.CodeTool,
            delimiter: window.Delimiter,
            embed: { class: window.Embed, config: { services: { youtube: true } } },
            checklist: { class: window.Checklist },
            table: { class: window.Table, inlineToolbar: true },
        },
        data: {
            blocks: [
