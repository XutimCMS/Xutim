                        <i class="ph ph-sidebar text-xs"></i>
                        Sidebar
                    </button>
                </div>
            </div>
        </div>

        {# Language bar #}
        <div class="border-b border-border">
            <div class="mx-auto max-w-7xl px-4 py-2 lg:px-6">
                <div class="flex items-center gap-1 flex-wrap">
                    {% set editMainLocales = ['de', 'en', 'es', 'fr', 'it', 'pl', 'pt', 'zh_Hant'] %}
                    {% set editExtLocales = ['ar', 'be', 'bn', 'ca', 'cs', 'da', 'el', 'et', 'fi', 'hi', 'hr', 'hu', 'id', 'ja', 'km', 'ko', 'lt', 'lv', 'my', 'nl', 'no', 'ro', 'ru', 'sk', 'sl', 'sq', 'sr', 'sv', 'sw', 'th', 'tl', 'uk', 'vl', 'zh_Hans'] %}
                    {% for l in editMainLocales %}
                        <button onclick="selectLang(this)" class="lang-btn inline-flex items-center gap-1 rounded-md border px-1.5 py-0.5 text-[11px] font-medium transition-colors {{ l == 'en' ? 'border-accent bg-accent text-white dark:text-black' : 'border-border text-content-secondary hover:border-border-strong' }}">
                            <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
                            {{ l }}
                        </button>
                    {% endfor %}
                    <div class="relative">
                        <button onclick="this.nextElementSibling.classList.toggle('hidden'); this.nextElementSibling.querySelector('input')?.focus()" class="lang-more-btn inline-flex items-center gap-1 rounded-md border border-dashed border-border-strong px-1.5 py-0.5 text-[11px] font-medium text-content-tertiary hover:border-accent hover:text-accent transition-colors">
                            <i class="ph ph-plus text-xs"></i>
