                <div class="flex items-center gap-2 shrink-0 ml-3">
                    <button class="hidden sm:inline-flex items-center gap-1.5 rounded-md border border-border px-2.5 py-1 text-[13px] text-content-secondary hover:bg-surface-raised">
                        <i class="ph ph-clock text-xs"></i>
