                    Save and publish
                    <i class="ph ph-caret-down text-xs"></i>
                </button>
                <div class="ml-auto text-[11px] text-content-tertiary">Last saved 2 min ago</div>
            </div>
        </div>
    </main>

    {# ================================================================ #}
    {# VIEW: PAGE LIST (tree)                                           #}
    {# ================================================================ #}
    <main id="view-pages" class="view hidden p-4 lg:p-6 max-w-7xl mx-auto">
        <div class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <h1 class="text-lg font-semibold">Pages</h1>
            <div class="flex items-center gap-2">
                <button class="inline-flex items-center gap-1.5 rounded-md border border-border px-3 py-1.5 text-[13px] text-content-secondary hover:bg-surface-raised">Translation list</button>
                <button class="inline-flex items-center gap-1.5 rounded-md border border-border px-3 py-1.5 text-[13px] text-content-secondary hover:bg-surface-raised">
                    <i class="ph ph-plus text-xs"></i>
                    New article
                </button>
                <button class="inline-flex items-center gap-1.5 rounded-md bg-accent px-3 py-1.5 text-[13px] font-medium text-white hover:bg-accent-hover dark:text-black">
                    <i class="ph ph-plus text-xs"></i>
                    New page
                </button>
            </div>
        </div>

        {# Language selector #}
        <div class="mb-4 flex items-center gap-1 flex-wrap">
            {% for l in mainLocales %}
                <button onclick="selectLang(this)" class="lang-btn rounded-md border px-2 py-0.5 text-[11px] font-medium transition-colors {{ l == 'en' ? 'border-accent bg-accent text-white dark:text-black' : 'border-border text-content-secondary hover:border-border-strong' }}">{{ l }}</button>
            {% endfor %}
            <div class="relative">
                <button onclick="this.nextElementSibling.classList.toggle('hidden'); this.nextElementSibling.querySelector('input')?.focus()" class="lang-more-btn rounded-md border border-dashed border-border-strong px-2 py-0.5 text-[11px] font-medium text-content-tertiary hover:border-accent hover:text-accent transition-colors">
                    + {{ extLocales|length }} more
                </button>
                <div class="hidden absolute left-0 top-full mt-1 z-50 w-64 rounded-lg border border-border bg-surface shadow-lg">
                    <div class="p-2 border-b border-border">
                        <input type="text" placeholder="Search language..." oninput="filterLangs(this)" class="w-full rounded-md border border-border bg-surface px-2.5 py-1.5 text-[12px] placeholder:text-content-tertiary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"/>
                    </div>
                    <div class="p-1.5 max-h-48 overflow-y-auto grid grid-cols-4 gap-0.5">
                        {% for l in extLocales %}
                            <button onclick="selectLang(this); this.closest('.relative').querySelector('.lang-more-btn').nextElementSibling.classList.add('hidden')" class="lang-btn lang-option rounded-md px-2 py-1.5 text-[11px] font-medium text-content-secondary hover:bg-surface-raised hover:text-content transition-colors" data-lang="{{ l }}">{{ l }}</button>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        {# Tree View #}
        <div class="rounded-xl border border-border min-w-0">
            {% set pages = [
                {name: 'The Community', depth: 0, hasChildren: true, expanded: false, status: 'published'},
                {name: 'Prayer & Reflection', depth: 0, hasChildren: true, expanded: false, status: 'published'},
                {name: 'Coming to the retreat', depth: 0, hasChildren: true, expanded: true, status: 'published'},
                {name: 'Registration', depth: 1, hasChildren: true, expanded: false, status: 'published'},
                {name: 'Arriving with a group', depth: 1, hasChildren: false, expanded: false, status: 'published', lang: 'es'},
                {name: 'Program of a typical day', depth: 1, hasChildren: false, expanded: false, status: 'published'},
                {name: 'Become a volunteer', depth: 1, hasChildren: false, expanded: false, status: 'published'},
                {name: 'One week of silent retreat', depth: 1, hasChildren: false, expanded: false, status: 'published'},
                {name: 'Financial contribution', depth: 1, hasChildren: true, expanded: true, status: 'published'},
                {name: 'Banking details', depth: 2, hasChildren: false, expanded: false, status: 'published'},
                {name: 'Contributions by country', depth: 2, hasChildren: false, expanded: false, status: 'partial'},
                {name: 'Accommodation', depth: 1, hasChildren: false, expanded: false, status: 'published'},
                {name: 'Plan your journey', depth: 1, hasChildren: false, expanded: false, status: 'published'},
                {name: 'Around the World', depth: 0, hasChildren: true, expanded: false, status: 'published'},
                {name: 'Other', depth: 0, hasChildren: true, expanded: false, status: 'published'},
                {name: 'Multimedia', depth: 0, hasChildren: true, expanded: false, status: 'published'},
                {name: 'Safeguarding', depth: 0, hasChildren: true, expanded: false, status: 'published'}
            ] %}

            <div class="divide-y divide-border">
                {% for page in pages %}
                <div class="group flex items-center hover:bg-surface-raised transition-colors" style="--depth: {{ page.depth }}">
                    <div class="tree-indent flex flex-1 items-center gap-1.5 px-4 py-2.5">
                        {% if page.depth > 0 %}
                            <span class="text-content-tertiary text-[13px] mr-0.5">└</span>
                        {% endif %}
                        {% if page.hasChildren %}
                            <button class="rounded p-0.5 hover:bg-surface-raised">
                                <i class="ph ph-caret-down text-xs text-content-tertiary {{ page.expanded ? '' : '-rotate-90' }} transition-transform"></i>
                            </button>
                        {% else %}
                            <span class="w-[22px]"></span>
                        {% endif %}
                        <span class="h-2 w-2 rounded-full shrink-0 {{ page.status == 'published' ? 'bg-green-500' : (page.status == 'partial' ? 'bg-blue-500' : 'bg-gray-400') }}"></span>
                        {% if page.lang is defined %}
                            <span class="inline-flex rounded border border-border px-1 py-0.5 text-[10px] font-medium text-content-tertiary">{{ page.lang }}</span>
                        {% endif %}
                        <span class="text-[13px] font-medium">{{ page.name }}</span>
                    </div>
                    <button class="opacity-0 group-hover:opacity-100 mr-3 rounded-md p-1 hover:bg-surface-raised transition-opacity">
                        <i class="ph ph-dots-three text-content-tertiary"></i>
                    </button>
                </div>
                {% endfor %}
            </div>

            <div class="border-t border-border px-4 py-3 space-y-1.5">
                <a href="#" class="flex items-center gap-2 text-[13px] text-accent hover:underline">
                    <i class="ph ph-archive text-xs"></i>
                    Show archived pages
                </a>
                <a href="#" class="flex items-center gap-2 text-[13px] text-accent hover:underline">
                    <i class="ph ph-translate text-xs"></i>
                    Show only translated pages
                </a>
            </div>
        </div>
    </main>

    {# ================================================================ #}
    {# VIEW: COMPONENTS                                                  #}
    {# ================================================================ #}
    <main id="view-components" class="view hidden p-4 lg:p-6 max-w-5xl mx-auto">
        <div class="mb-8">
            <h1 class="text-lg font-semibold">Components</h1>
            <p class="mt-1 text-[13px] text-content-secondary">UI patterns for the redesign</p>
        </div>

        {# ---- TOAST NOTIFICATIONS ---- #}
        <section class="mb-10">
            <h2 class="text-sm font-semibold mb-4 pb-2 border-b border-border">Demos</h2>
            <div class="flex flex-wrap gap-2 mb-6">
                <button onclick="toggleImpersonation()" class="rounded-md border border-amber-300 bg-amber-50 px-3 py-1.5 text-[13px] font-medium text-amber-700 hover:bg-amber-100 dark:border-amber-500/30 dark:bg-amber-500/10 dark:text-amber-400">Toggle impersonation bar</button>
                <a href="#" onclick="openModal('login-modal'); return false;" class="rounded-md border border-border px-3 py-1.5 text-[13px] font-medium hover:bg-surface-raised">Preview login page</a>
            </div>

            <h3 class="text-sm font-semibold mb-4 pb-2 border-b border-border">Toast Notifications</h3>
            <div class="flex flex-wrap gap-2 mb-4">
                <button onclick="showToast('success', 'Article published', 'The article has been published successfully.')" class="rounded-md bg-accent px-3 py-1.5 text-[13px] font-medium text-white dark:text-black hover:bg-accent-hover">Success toast</button>
                <button onclick="showToast('error', 'Failed to save', 'There was an error saving the article. Please try again.')" class="rounded-md bg-red-600 px-3 py-1.5 text-[13px] font-medium text-white hover:bg-red-700">Error toast</button>
                <button onclick="showToast('warning', 'Unsaved changes', 'You have unsaved changes that will be lost.')" class="rounded-md bg-amber-500 px-3 py-1.5 text-[13px] font-medium text-white hover:bg-amber-600">Warning toast</button>
                <button onclick="showToast('info', 'Translation synced', 'Czech translation has been synced with the reference.')" class="rounded-md border border-border px-3 py-1.5 text-[13px] font-medium hover:bg-surface-raised">Info toast</button>
            </div>
        </section>

        {# ---- MODALS ---- #}
        <section class="mb-10">
            <h2 class="text-sm font-semibold mb-4 pb-2 border-b border-border">Modals & Dialogs</h2>
            <div class="flex flex-wrap gap-2 mb-4">
                <button onclick="openModal('delete-modal')" class="rounded-md border border-red-200 px-3 py-1.5 text-[13px] font-medium text-red-600 hover:bg-red-50 dark:border-red-500/30 dark:text-red-400 dark:hover:bg-red-500/10">Delete confirmation</button>
                <button onclick="openModal('form-modal')" class="rounded-md border border-border px-3 py-1.5 text-[13px] font-medium hover:bg-surface-raised">Form modal</button>
                <button onclick="openModal('media-modal')" class="rounded-md border border-border px-3 py-1.5 text-[13px] font-medium hover:bg-surface-raised">Media picker</button>
            </div>
        </section>

        {# ---- FORM ELEMENTS ---- #}
        <section class="mb-10">
            <h2 class="text-sm font-semibold mb-4 pb-2 border-b border-border">Form Elements</h2>
            <div class="max-w-2xl space-y-5">
                {# Text input #}
                <div>
                    <label class="block text-[12px] font-medium text-content-secondary mb-1">Text input</label>
                    <input type="text" value="Sample value" class="w-full rounded-lg border border-border bg-surface px-3 py-2 text-[13px] focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"/>
                </div>

                {# Input with error #}
                <div>
                    <label class="block text-[12px] font-medium text-content-secondary mb-1">Input with error <span class="text-red-500">*</span></label>
                    <input type="text" value="" class="w-full rounded-lg border border-red-300 bg-surface px-3 py-2 text-[13px] focus:border-red-500 focus:outline-none focus:ring-1 focus:ring-red-500 dark:border-red-500/50"/>
                    <p class="mt-1 text-[11px] text-red-600 dark:text-red-400">This field is required.</p>
                </div>

                {# Textarea #}
                <div>
                    <label class="block text-[12px] font-medium text-content-secondary mb-1">Textarea</label>
                    <textarea rows="3" placeholder="Add a description..." class="w-full rounded-lg border border-border bg-surface px-3 py-2 text-[13px] placeholder:text-content-tertiary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"></textarea>
                    <p class="mt-1 text-[11px] text-content-tertiary">Helper text goes here. Max 160 characters.</p>
                </div>

                {# Select #}
                <div>
                    <label class="block text-[12px] font-medium text-content-secondary mb-1">Select</label>
                    <select class="w-full rounded-lg border border-border bg-surface px-3 py-2 text-[13px] focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent">
                        <option>default-regular</option>
                        <option>full-width</option>
                        <option>sidebar-layout</option>
                    </select>
                </div>

                {# Multi-select / Tag input #}
                <div>
                    <label class="block text-[12px] font-medium text-content-secondary mb-1">Tag input (multi-select)</label>
                    <div class="flex flex-wrap gap-1.5 rounded-lg border border-border p-2 focus-within:border-accent focus-within:ring-1 focus-within:ring-accent">
                        {% for tag in ['Visits', 'Monthly Bible commentaries', 'Local Events'] %}
                        <span class="inline-flex items-center gap-1 rounded-md bg-surface-raised px-2 py-1 text-[12px] font-medium">
                            {{ tag }}
                            <button class="text-content-tertiary hover:text-content"><i class="ph ph-x text-[10px]"></i></button>
                        </span>
                        {% endfor %}
                        <input type="text" placeholder="Add tag..." class="flex-1 min-w-[80px] border-0 bg-transparent px-1 py-1 text-[12px] placeholder:text-content-tertiary focus:outline-none"/>
                    </div>
                </div>

                {# Checkbox group #}
                <div>
                    <label class="block text-[12px] font-medium text-content-secondary mb-2">Checkboxes</label>
                    <div class="space-y-2">
                        {% for opt in ['Show in news feed', 'Allow comments', 'Pin to top'] %}
                        <label class="flex items-center gap-2.5 cursor-pointer">
                            <input type="checkbox" {{ loop.first ? 'checked' : '' }} class="h-4 w-4 rounded border-border text-accent focus:ring-accent"/>
                            <span class="text-[13px]">{{ opt }}</span>
                        </label>
                        {% endfor %}
                    </div>
                </div>

                {# Radio group #}
                <div>
                    <label class="block text-[12px] font-medium text-content-secondary mb-2">Radio buttons</label>
                    <div class="space-y-2">
                        {% for opt in ['All languages', 'Selected languages only', 'None'] %}
                        <label class="flex items-center gap-2.5 cursor-pointer">
                            <input type="radio" name="translate-demo" {{ loop.first ? 'checked' : '' }} class="h-4 w-4 border-border text-accent focus:ring-accent"/>
                            <span class="text-[13px]">{{ opt }}</span>
                        </label>
                        {% endfor %}
                    </div>
                </div>

                {# Toggle switch #}
                <div class="flex items-center justify-between rounded-lg border border-border p-4">
                    <div>
                        <div class="text-[13px] font-medium">Published</div>
                        <div class="text-[11px] text-content-secondary mt-0.5">Make this visible on the public site</div>
                    </div>
                    <button onclick="this.dataset.on = this.dataset.on === 'true' ? 'false' : 'true'" data-on="true" class="relative inline-flex h-6 w-11 shrink-0 items-center rounded-full transition-colors [&[data-on='true']]:bg-green-500 [&[data-on='false']]:bg-gray-300 dark:[&[data-on='false']]:bg-neutral-600">
                        <span class="inline-block h-4 w-4 rounded-full bg-white shadow transition-transform [button[data-on='true']_&]:translate-x-6 [button[data-on='false']_&]:translate-x-1"></span>
                    </button>
                </div>

                {# Date picker #}
                <div>
                    <label class="block text-[12px] font-medium text-content-secondary mb-1">Date & time</label>
                    <div class="flex gap-2">
                        <div class="relative flex-1">
                            <i class="ph ph-calendar-blank absolute left-3 top-1/2 -translate-y-1/2 text-content-tertiary"></i>
                            <input type="text" value="Apr 3, 2026" class="w-full rounded-lg border border-border bg-surface py-2 pl-9 pr-3 text-[13px] focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"/>
                        </div>
                        <div class="relative w-32">
                            <i class="ph ph-clock absolute left-3 top-1/2 -translate-y-1/2 text-content-tertiary"></i>
                            <input type="text" value="15:30" class="w-full rounded-lg border border-border bg-surface py-2 pl-9 pr-3 text-[13px] focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"/>
                        </div>
                    </div>
                </div>

                {# File upload / Dropzone #}
