                            <p class="text-[12px] text-gray-400">youtube.com/embed/dQw4w9WgXcQ</p>
                        </div>
                    </div>
                    <p class="mt-2 text-center text-[12px] text-content-tertiary">Songs and prayers from the community</p>
                </div>

                {# --- Delimiter --- #}
                <div class="p-5">
                    <div class="text-[10px] font-medium uppercase tracking-wider text-content-tertiary mb-2">Delimiter</div>
                    <div class="flex items-center justify-center py-2">
                        <span class="text-content-tertiary tracking-[0.5em] text-lg">***</span>
                    </div>
                </div>

                {# --- Foldable section --- #}
                <div class="p-5">
                    <div class="text-[10px] font-medium uppercase tracking-wider text-content-tertiary mb-2">Foldable Section</div>
                    <details class="rounded-lg border border-border" open>
                        <summary class="flex items-center gap-2 px-4 py-3 cursor-pointer select-none hover:bg-surface-raised transition-colors text-[14px] font-medium">
                            <i class="ph ph-caret-right text-xs text-content-tertiary transition-transform [details[open]_&]:rotate-90"></i>
                            Practical information for your stay
                        </summary>
                        <div class="px-4 pb-4 text-[14px] leading-relaxed text-content-secondary border-t border-border pt-3">
                            <p>Bring comfortable clothes, a sleeping bag, and a Bible. Meals are provided. Please arrive before 14:00 on the first day.</p>
                        </div>
                    </details>
                </div>

                {# --- Tag list block --- #}
                <div class="p-5">
                    <div class="text-[10px] font-medium uppercase tracking-wider text-content-tertiary mb-2">Tag List</div>
                    <div class="flex flex-wrap gap-1.5">
                        {% for tag in ['Visits', 'Holy Land', 'Peace', 'Ecumenism'] %}
                        <a href="#" class="inline-flex items-center rounded-md bg-accent-subtle px-2.5 py-1 text-[12px] font-medium text-accent hover:bg-accent/10 transition-colors">{{ tag }}</a>
                        {% endfor %}
                    </div>
                </div>

                {# --- Content link (article) --- #}
                <div class="p-5">
                    <div class="text-[10px] font-medium uppercase tracking-wider text-content-tertiary mb-2">Content Link (Article)</div>
                    <a href="#" class="flex items-center gap-3 rounded-lg border border-border p-3 hover:bg-surface-raised transition-colors group">
                        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-surface-raised">
                            <i class="ph ph-newspaper text-lg text-content-tertiary"></i>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="text-[12px] text-content-tertiary">Linked article</div>
                            <div class="text-[13px] font-medium truncate group-hover:text-accent transition-colors">The Mystery of the Passover</div>
                        </div>
                        <i class="ph ph-arrow-right text-content-tertiary group-hover:text-accent transition-colors"></i>
                    </a>
                </div>

                {# --- Content link (page) --- #}
                <div class="p-5">
                    <div class="text-[10px] font-medium uppercase tracking-wider text-content-tertiary mb-2">Content Link (Page)</div>
                    <a href="#" class="flex items-center gap-3 rounded-lg border border-border p-3 hover:bg-surface-raised transition-colors group">
                        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-surface-raised">
                            <i class="ph ph-file-text text-lg text-content-tertiary"></i>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="text-[12px] text-content-tertiary">Linked page</div>
                            <div class="text-[13px] font-medium truncate group-hover:text-accent transition-colors">Coming to the retreat</div>
                        </div>
                        <i class="ph ph-arrow-right text-content-tertiary group-hover:text-accent transition-colors"></i>
                    </a>
                </div>

                {# --- Layout block (2 columns) --- #}
                <div class="p-5">
                    <div class="text-[10px] font-medium uppercase tracking-wider text-content-tertiary mb-2">Layout Block (2 columns)</div>
                    <div class="rounded-lg border border-dashed border-border-strong">
                        <div class="flex items-center gap-2 px-3 py-2 border-b border-dashed border-border-strong">
                            <span class="inline-flex items-center rounded bg-surface-raised px-1.5 py-0.5 text-[10px] font-medium text-content-tertiary">Sidebar left</span>
                        </div>
                        <div class="grid grid-cols-[1fr_2fr] divide-x divide-dashed divide-border-strong">
                            <div class="p-3">
                                <div class="text-[11px] text-content-tertiary mb-2">Sidebar</div>
                                <div class="rounded border border-dashed border-border p-3 text-center text-[12px] text-content-tertiary">
                                    <i class="ph ph-plus text-xs"></i> Add block
                                </div>
                            </div>
                            <div class="p-3">
                                <div class="text-[11px] text-content-tertiary mb-2">Main content</div>
                                <p class="text-[14px] leading-relaxed text-content-secondary">This is the main content area of the layout. It takes up 2/3 of the width while the sidebar takes 1/3.</p>
                            </div>
                        </div>
                    </div>
                </div>

                {# --- Block selector (predefined code block) --- #}
                <div class="p-5">
                    <div class="text-[10px] font-medium uppercase tracking-wider text-content-tertiary mb-2">Code Block (predefined)</div>
                    <div class="rounded-lg border border-border p-4 bg-surface-raised/50">
                        <div class="flex items-center gap-2 text-[13px]">
                            <i class="ph ph-puzzle-piece text-content-tertiary"></i>
                            <span class="font-medium">registration-form</span>
                            <span class="text-content-tertiary">— Custom block</span>
                        </div>
                    </div>
                </div>

            </div>
        </section>

    </main>

    {# ==================== GLOBAL MODALS ==================== #}

    {# Delete confirmation modal #}
    <div id="delete-modal" class="modal-overlay fixed inset-0 z-[60] hidden items-center justify-center bg-black/50 p-4" onclick="if(event.target===this)closeModal(this.id)">
        <div class="w-full max-w-sm rounded-xl bg-surface border border-border shadow-xl">
            <div class="p-5">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-red-50 dark:bg-red-500/10 mb-3">
                    <i class="ph ph-trash text-lg text-red-600 dark:text-red-400"></i>
                </div>
                <h3 class="text-[15px] font-semibold">Delete article?</h3>
                <p class="mt-2 text-[13px] text-content-secondary leading-relaxed">This will permanently delete <strong>"A brother went to Palestine, Israel and Jordan"</strong> and all its translations. This action cannot be undone.</p>
            </div>
            <div class="flex items-center justify-end gap-2 border-t border-border px-5 py-3">
                <button onclick="closeModal('delete-modal')" class="rounded-md border border-border px-3 py-1.5 text-[13px] font-medium hover:bg-surface-raised">Cancel</button>
                <button onclick="closeModal('delete-modal'); showToast('success', 'Article deleted', 'The article has been permanently deleted.')" class="rounded-md bg-red-600 px-3 py-1.5 text-[13px] font-medium text-white hover:bg-red-700">Delete</button>
            </div>
        </div>
    </div>

    {# Form modal #}
    <div id="form-modal" class="modal-overlay fixed inset-0 z-[60] hidden items-center justify-center bg-black/50 p-4" onclick="if(event.target===this)closeModal(this.id)">
        <div class="w-full max-w-lg rounded-xl bg-surface border border-border shadow-xl">
            <div class="flex items-center justify-between border-b border-border px-5 py-3.5">
                <h3 class="text-[15px] font-semibold">Create new tag</h3>
                <button onclick="closeModal('form-modal')" class="rounded-md p-1 hover:bg-surface-raised">
                    <i class="ph ph-x text-content-tertiary"></i>
                </button>
            </div>
            <div class="p-5 space-y-4">
                <div>
                    <label class="block text-[12px] font-medium text-content-secondary mb-1">Name <span class="text-red-500">*</span></label>
                    <input type="text" placeholder="Enter tag name" class="w-full rounded-lg border border-border bg-surface px-3 py-2 text-[13px] placeholder:text-content-tertiary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"/>
                </div>
                <div>
                    <label class="block text-[12px] font-medium text-content-secondary mb-1">Slug</label>
                    <input type="text" placeholder="auto-generated-from-name" class="w-full rounded-lg border border-border bg-surface px-3 py-2 text-[13px] placeholder:text-content-tertiary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"/>
                </div>
                <div>
                    <label class="block text-[12px] font-medium text-content-secondary mb-1">Color</label>
                    <div class="flex items-center gap-2">
                        {% for color in ['bg-gray-400', 'bg-red-500', 'bg-orange-400', 'bg-green-500', 'bg-blue-500', 'bg-purple-500'] %}
                        <button class="h-6 w-6 rounded-full {{ color }} {{ loop.first ? 'ring-2 ring-accent ring-offset-2 ring-offset-surface' : '' }} hover:scale-110 transition-transform"></button>
                        {% endfor %}
                    </div>
                </div>
            </div>
            <div class="flex items-center justify-end gap-2 border-t border-border px-5 py-3">
                <button onclick="closeModal('form-modal')" class="rounded-md border border-border px-3 py-1.5 text-[13px] font-medium hover:bg-surface-raised">Cancel</button>
                <button onclick="closeModal('form-modal'); showToast('success', 'Tag created', 'New tag has been created successfully.')" class="rounded-md bg-accent px-3 py-1.5 text-[13px] font-medium text-white hover:bg-accent-hover dark:text-black">Create tag</button>
            </div>
        </div>
    </div>

    {# Media picker modal #}
    <div id="media-modal" class="modal-overlay fixed inset-0 z-[60] hidden items-center justify-center bg-black/50 p-4" onclick="if(event.target===this)closeModal(this.id)">
        <div class="w-full max-w-3xl max-h-[80vh] flex flex-col rounded-xl bg-surface border border-border shadow-xl">
            <div class="flex items-center justify-between border-b border-border px-5 py-3.5 shrink-0">
                <h3 class="text-[15px] font-semibold">Select media</h3>
                <button onclick="closeModal('media-modal')" class="rounded-md p-1 hover:bg-surface-raised">
                    <i class="ph ph-x text-content-tertiary"></i>
                </button>
            </div>
            {# Toolbar #}
            <div class="flex items-center gap-2 border-b border-border px-5 py-2.5 shrink-0">
                <div class="relative flex-1 max-w-xs">
                    <i class="ph ph-magnifying-glass absolute left-2.5 top-1/2 -translate-y-1/2 text-content-tertiary text-xs"></i>
                    <input type="text" placeholder="Search media..." class="w-full rounded-md border border-border bg-surface py-1.5 pl-8 pr-3 text-[12px] placeholder:text-content-tertiary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"/>
                </div>
                <select class="rounded-md border border-border bg-surface px-2 py-1.5 text-[12px] focus:border-accent focus:outline-none">
                    <option>All types</option>
                    <option>Images</option>
                    <option>Documents</option>
                    <option>Videos</option>
                </select>
                <button class="ml-auto inline-flex items-center gap-1.5 rounded-md border border-border px-2.5 py-1.5 text-[12px] font-medium hover:bg-surface-raised">
                    <i class="ph ph-cloud-arrow-up text-xs"></i> Upload
                </button>
            </div>
            {# Image grid #}
            <div class="flex-1 overflow-y-auto p-4">
                <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-2">
                    {% for i in 1..15 %}
                    <button onclick="this.classList.toggle('ring-2'); this.classList.toggle('ring-accent')" class="group relative aspect-square rounded-lg overflow-hidden border border-border bg-surface-raised hover:border-border-strong transition-colors">
                        <div class="absolute inset-0 flex items-center justify-center">
                            <i class="ph ph-image text-2xl text-content-tertiary/50"></i>
                        </div>
                        {% if i <= 3 %}
                        <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-black/60 to-transparent p-1.5 opacity-0 group-hover:opacity-100 transition-opacity">
                            <p class="text-[10px] text-white truncate">image-{{ i }}.jpg</p>
                        </div>
                        {% endif %}
                    </button>
                    {% endfor %}
                </div>
            </div>
            {# Footer #}
            <div class="flex items-center justify-between border-t border-border px-5 py-3 shrink-0">
                <span class="text-[12px] text-content-secondary">0 selected</span>
                <div class="flex gap-2">
                    <button onclick="closeModal('media-modal')" class="rounded-md border border-border px-3 py-1.5 text-[13px] font-medium hover:bg-surface-raised">Cancel</button>
                    <button onclick="closeModal('media-modal'); showToast('info', 'Media selected', 'Image has been attached to the article.')" class="rounded-md bg-accent px-3 py-1.5 text-[13px] font-medium text-white hover:bg-accent-hover dark:text-black">Insert selected</button>
                </div>
            </div>
        </div>
    </div>

    {# ================================================================ #}
    {# VIEW: SETTINGS                                                   #}
    {# ================================================================ #}
    <main id="view-settings" class="view hidden p-4 lg:p-6 max-w-7xl mx-auto">
        <div class="mb-5">
            <h1 class="text-lg font-semibold">Settings</h1>
        </div>
        <div class="flex flex-col gap-6 lg:flex-row">
            <nav class="flex lg:w-44 lg:flex-col gap-0.5 shrink-0">
                <a href="#" class="rounded-md bg-accent-subtle px-3 py-2 text-[13px] font-medium text-accent">Site</a>
                <a href="#" class="rounded-md px-3 py-2 text-[13px] text-content-secondary hover:bg-surface-raised">Users</a>
                <a href="#" class="rounded-md px-3 py-2 text-[13px] text-content-secondary hover:bg-surface-raised">Menu</a>
                <a href="#" class="rounded-md px-3 py-2 text-[13px] text-content-secondary hover:bg-surface-raised">Redirect</a>
            </nav>
            <div class="flex-1 max-w-2xl">
                <div class="rounded-xl border border-border">
                    <div class="border-b border-border px-5 py-4">
                        <h3 class="text-[15px] font-semibold">Site Settings</h3>
                        <p class="mt-1 text-[12px] text-content-secondary">Configure your site preferences</p>
                    </div>
                    <div class="divide-y divide-border">
                        <div class="px-5 py-4">
                            <label class="block text-[12px] font-medium text-content-secondary mb-1.5">Content languages <span class="text-red-500">*</span></label>
                            <div class="flex flex-wrap gap-1.5 rounded-lg border border-border p-2">
                                {% for lang in ['English', 'French', 'German', 'Polish', 'Portuguese', 'Spanish'] %}
                                <span class="inline-flex items-center gap-1 rounded-md bg-surface-raised px-2 py-1 text-[12px] font-medium">
                                    {{ lang }}
                                    <button class="text-content-tertiary hover:text-content"><i class="ph ph-x text-[10px]"></i></button>
                                </span>
                                {% endfor %}
                            </div>
                        </div>
                        <div class="px-5 py-4">
                            <label class="block text-[12px] font-medium text-content-secondary mb-1.5">Extended content languages</label>
                            <div class="flex flex-wrap gap-1.5 rounded-lg border border-border p-2 max-h-24 overflow-y-auto">
                                {% for lang in ['Albanian', 'Arabic', 'Bangla', 'Belarusian', 'Burmese', 'Catalan', 'Chinese (Simplified)', 'Croatian', 'Czech', 'Danish', 'Dutch', 'Estonian', 'Finnish'] %}
                                <span class="inline-flex items-center gap-1 rounded-md bg-surface-raised px-2 py-1 text-[12px] font-medium">
                                    {{ lang }}
                                    <button class="text-content-tertiary hover:text-content"><i class="ph ph-x text-[10px]"></i></button>
                                </span>
                                {% endfor %}
                            </div>
                        </div>
                        <div class="px-5 py-4">
                            <label class="block text-[12px] font-medium text-content-secondary mb-1.5">Theme</label>
                            <select class="w-full rounded-lg border border-border bg-surface px-3 py-2 text-[13px] focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent">
                                <option>tailwind</option>
                                <option>default</option>
                            </select>
                        </div>
                        <div class="px-5 py-4">
                            <label class="block text-[12px] font-medium text-content-secondary mb-1.5">Mail sender</label>
                            <input type="email" value="admin@example.com" class="w-full rounded-lg border border-border bg-surface px-3 py-2 text-[13px] focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"/>
                        </div>
                        <div class="px-5 py-4">
                            <label class="block text-[12px] font-medium text-content-secondary mb-1.5">Reference language</label>
                            <select class="w-full rounded-lg border border-border bg-surface px-3 py-2 text-[13px] focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent">
                                <option>English</option>
                                <option>French</option>
                            </select>
                        </div>
                        <div class="px-5 py-4">
                            <label class="block text-[12px] font-medium text-content-secondary mb-1.5">Untranslated article age limit (days) <span class="text-red-500">*</span></label>
                            <div class="flex items-center gap-2">
                                <div class="flex rounded-lg border border-border overflow-hidden">
                                    <button class="px-3 py-1.5 text-[12px] font-medium bg-accent text-white dark:text-black">1 month</button>
                                    <button class="px-3 py-1.5 text-[12px] border-l border-border hover:bg-surface-raised">3 months</button>
                                    <button class="px-3 py-1.5 text-[12px] border-l border-border hover:bg-surface-raised">6 months</button>
                                </div>
                                <input type="number" value="30" class="w-20 rounded-lg border border-border bg-surface px-3 py-1.5 text-[13px] focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"/>
                                <span class="text-[13px] text-content-secondary">days</span>
                            </div>
                            <p class="mt-1.5 text-[11px] text-content-tertiary">Articles older than this will not appear in the translator dashboard.</p>
                        </div>
                    </div>
                    <div class="flex items-center justify-end gap-2 border-t border-border px-5 py-3">
                        <button class="rounded-md border border-border px-4 py-2 text-[13px] font-medium hover:bg-surface-raised">Cancel</button>
                        <button class="rounded-md bg-accent px-4 py-2 text-[13px] font-medium text-white hover:bg-accent-hover dark:text-black">Save changes</button>
                    </div>
                </div>
            </div>
        </div>
    </main>

    {# ================================================================ #}
    {# VIEW: MEDIA GALLERY                                              #}
    {# ================================================================ #}
    <main id="view-media" class="view hidden p-4 lg:p-6 max-w-7xl mx-auto">
        <div class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <h1 class="text-lg font-semibold">Media</h1>
            <div class="flex items-center gap-2">
                <button class="inline-flex items-center gap-1.5 rounded-md bg-accent px-3 py-1.5 text-[13px] font-medium text-white hover:bg-accent-hover dark:text-black">
                    <i class="ph ph-cloud-arrow-up text-sm"></i> Upload
                </button>
            </div>
        </div>
        {# Toolbar #}
        <div class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
            <div class="flex items-center gap-2">
                <div class="relative flex-1 max-w-xs">
                    <i class="ph ph-magnifying-glass absolute left-2.5 top-1/2 -translate-y-1/2 text-content-tertiary text-xs"></i>
                    <input type="text" placeholder="Search media..." class="w-full rounded-md border border-border bg-surface py-1.5 pl-8 pr-3 text-[13px] placeholder:text-content-tertiary focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"/>
                </div>
                <select class="rounded-md border border-border bg-surface px-2.5 py-1.5 text-[12px] focus:border-accent focus:outline-none">
                    <option>All types</option>
                    <option>Images</option>
                    <option>Documents</option>
                    <option>Videos</option>
                </select>
            </div>
            <div class="flex items-center gap-1">
                <button class="rounded-md p-1.5 bg-surface-raised text-content" title="Grid view"><i class="ph ph-squares-four text-sm"></i></button>
                <button class="rounded-md p-1.5 text-content-tertiary hover:bg-surface-raised" title="List view"><i class="ph ph-list text-sm"></i></button>
                <span class="ml-2 text-[12px] text-content-tertiary">1,204 files &middot; 3.2 GB</span>
            </div>
        </div>
        {# Grid #}
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-3">
            {% for i in 1..18 %}
            <div class="group relative rounded-lg border border-border overflow-hidden hover:border-border-strong transition-colors cursor-pointer {{ i == 3 ? 'ring-2 ring-accent' : '' }}">
                <div class="aspect-square bg-surface-raised flex items-center justify-center">
                    {% if i <= 12 %}
                        <i class="ph ph-image text-3xl text-content-tertiary/20"></i>
                    {% elseif i <= 15 %}
                        <div class="flex flex-col items-center">
                            <i class="ph ph-file-pdf text-2xl text-red-400"></i>
                            <span class="text-[10px] text-content-tertiary mt-1">PDF</span>
                        </div>
                    {% else %}
                        <div class="flex flex-col items-center">
                            <i class="ph ph-file-doc text-2xl text-blue-400"></i>
                            <span class="text-[10px] text-content-tertiary mt-1">DOC</span>
                        </div>
                    {% endif %}
                </div>
                <div class="px-2 py-1.5">
                    <p class="text-[11px] font-medium truncate">{% if i <= 12 %}photo-{{ '%03d'|format(i) }}.jpg{% elseif i <= 15 %}document-{{ i }}.pdf{% else %}report-{{ i }}.docx{% endif %}</p>
                    <p class="text-[10px] text-content-tertiary">{{ (i * 127) }} KB</p>
                </div>
                {# Hover actions #}
                <div class="absolute top-1.5 right-1.5 opacity-0 group-hover:opacity-100 transition-opacity flex gap-1">
                    <button class="flex h-6 w-6 items-center justify-center rounded-md bg-surface/90 border border-border shadow-sm hover:bg-surface" title="Download">
                        <i class="ph ph-download-simple text-xs"></i>
                    </button>
                    <button class="flex h-6 w-6 items-center justify-center rounded-md bg-surface/90 border border-border shadow-sm hover:bg-surface" title="Delete">
                        <i class="ph ph-trash text-xs text-red-500"></i>
                    </button>
                </div>
                {% if i == 3 %}
                <div class="absolute top-1.5 left-1.5">
                    <div class="flex h-5 w-5 items-center justify-center rounded bg-accent text-white dark:text-black"><i class="ph ph-check text-xs font-bold"></i></div>
                </div>
                {% endif %}
            </div>
            {% endfor %}
        </div>
        {# Pagination #}
        <div class="mt-4 flex items-center justify-between text-[13px]">
            <span class="text-content-secondary">Showing 1-18 of 1,204</span>
            <div class="flex items-center gap-1">
                <button class="rounded-md px-2.5 py-1 text-content-tertiary" disabled>&lsaquo; prev</button>
                <button class="rounded-md bg-accent px-2.5 py-1 font-medium text-white dark:text-black">1</button>
                <button class="rounded-md px-2.5 py-1 text-content-secondary hover:bg-surface-raised">2</button>
                <button class="rounded-md px-2.5 py-1 text-content-secondary hover:bg-surface-raised">3</button>
                <button class="rounded-md px-2.5 py-1 text-content-secondary hover:bg-surface-raised">next &rsaquo;</button>
            </div>
        </div>
    </main>

    {# ================================================================ #}
    {# VIEW: NOTIFICATIONS                                              #}
    {# ================================================================ #}
    <main id="view-notifications" class="view hidden p-4 lg:p-6 max-w-5xl mx-auto">
        <div class="mb-5 flex items-center justify-between">
