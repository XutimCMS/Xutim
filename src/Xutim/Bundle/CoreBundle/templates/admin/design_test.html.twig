                            <input type="text" value="a-brother-went-to-palestine-israel-and-jordan" class="w-full rounded-lg border border-border bg-surface px-3 py-2 text-[13px] focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"/>
