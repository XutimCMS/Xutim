{% extends '@XutimCore/admin/modalBase.html.twig' %}
{% import '@XutimCore/admin/common/forms.html.twig' as forms %}
{%
    set title = 'Are you sure you want to delete this menu entry?'|trans({}, 'admin')
%}

{% block pageTitle %}{{ title }}{% endblock %}

{% block body %}
    <div class="rounded-xl border border-border -mt-px">
        <div class="h-1 bg-red-600 rounded-t-xl"></div>
        <div class="p-4">
            <div class="text-center">
                <p>
                    <twig:ux:icon name="ph:warning" class="w-12 h-12 text-red-600 mb-2" />
                </p>
                <h3>{{ title }}</h3>
            </div>
        </div>

        <div class="px-4 py-3 border-t border-border">
            {{ form_start(form, {attr: {class: 'flex items-center'}}) }}
            <a
                href="{{ admin_path('admin_menu_list', {id: item.parent ? item.parent.id : null}) }}"
                class="text-sm font-medium mr-auto"
            >
                {{ 'Back to list'|trans({}, 'admin') }}
            </a>

            <twig:Xutim:Admin:Button
                variant="danger"
                tag="button"
                id="{{ form.delete.vars.id }}"
                name="{{ form.delete.vars.full_name }}"
                class="ml-auto"
                type="submit"
                data-turbo-frame="{{ app.request.headers.get('turbo-frame') ? '_top' : '' }}"
            >
                <twig:ux:icon name="ph:trash" class="icon" />
                {{ 'delete'|trans({}, 'admin')|capitalize }}
            </twig:Xutim:Admin:Button>
            {{ form_row(form._token) }}
            {{ form_end(form, {render_rest: false}) }}
        </div>
    </div>
{% endblock %}

{% block stream_success %}
    <turbo-stream action="refresh"></turbo-stream>

    <turbo-stream action="update" target="modal">
        <template></template>
    </turbo-stream>
{% endblock %}
