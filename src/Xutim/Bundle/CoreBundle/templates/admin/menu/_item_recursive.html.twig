{% set isSelectedItem = selectedItem and selectedItem.id.equals(item.id) %}

<li
    class="my-2 ml-3{{ isSelectedItem ? ' bg-amber-50 dark:bg-amber-900/20' : '' }}"
    id="menu-item-tree-{{ item.id }}"
>
    {% if node.children is empty %}
        <twig:ux:icon name="ph:caret-down" class="icon text-content" />
        {{
            _self.itemLine(items, node, item, child, loop.first, loop.last, selectedItem)
        }}
        {{ _self.subTree(items, node, item, child, path, selectedItem) }}
    {% else %}
        {%
            set detailsOpened = path|reduce((carry, sec, k) => carry is same as(true) or item.id.equals(sec.id), false)
        %}
        <details {{ detailsOpened ? ' open="open"' : '' }} class="text-content">
            <summary class="ml-2{{ isSelectedItem ? ' font-bold' : '' }}">
                {{
                    _self.itemLine(items, node, item, child, loop.first, loop.last, selectedItem)
                }}
            </summary>
            {{ _self.subTree(items, node, item, child, path, selectedItem) }}
        </details>
    {% endif %}
</li>

{% macro subTree(items, node, item, child, path, selectedItem) %}
    {% if node.children is not empty %}
        <ul class="list-none">
            {% for childId in node.children %}
                {{
                    include('@XutimCore/admin/menu/_item_recursive.html.twig', {
                    node: items[childId],
                    item: items[childId].item,
                    child: true,
                    path: path,
                    selectedItem: selectedItem,
                    })
                }}
            {% endfor %}
        </ul>
    {% endif %}
{% endmacro %}

{% macro itemLine(items, node, item, child, first, last, selectedItem) %}
    {% set isSelectedItem = selectedItem and selectedItem.id.equals(item.id) %}
    {% set translation = item.objectTranslation(content_context_language()) %}

    <span class="mr-1"></span>

    {%
        import '@XutimCore/admin/common/translatable.html.twig' as translatable
    %}
    {{ translatable.languageBadge(translation) }}

    {% if item.hasArticle() %}
        <twig:ux:icon name="ph:newspaper" class="icon mr-2" />
    {% elseif item.hasPage() %}
        <twig:ux:icon name="ph:folder-simple" class="icon mr-2" />
    {% else %}
        <twig:ux:icon name="ph:tag" class="icon mr-2" />
    {% endif %}
    <a href="{{ admin_path('admin_menu_list', {id: item.id}) }}">
        <span class="text-content{{ isSelectedItem ? ' font-bold' : '' }}">
            {{
                translation.title is defined ? translation.title : translation.name
            }}
        </span>
    </a>

    {%
        if is_granted(constant('Xutim\\SecurityBundle\\Security\\UserRoles::ROLE_EDITOR'))
    %}
        <div class="dropdown float-right relative">
            <a href="#" class="text-content-secondary" data-bs-toggle="dropdown">
                <twig:ux:icon name="ph:dots-three" class="icon" />
            </a>
            <div class="dropdown-menu dropdown-menu-end">
                {% set showUrl = null %}
                {% if item.hasArticle() %}{%
                        set showUrl = 'admin_article_show'
                    %}{% endif %}
                {% if item.hasPage() %}{% set showUrl = 'admin_page_list' %}{%
                    endif
                %}
                {% if showUrl %}
                    <twig:Xutim:Admin:Button
                        tag="a"
                        variant="dropdown"
                        href="{{ admin_path(showUrl, {id: item.object.id}) }}"
                    >
                        <twig:ux:icon name="ph:magnifying-glass" class="icon mr-2" />
                        {{ 'show'|trans|capitalize }}
                    </twig:Xutim:Admin:Button>
                {% endif %}
                <twig:Xutim:Admin:Button
                    tag="a"
                    variant="dropdown"
                    data-turbo-frame="modal"
                    href="{{ admin_path('admin_menu_item_edit', {id: item.id}) }}"
                >
                    <twig:ux:icon name="ph:pencil-simple" class="icon mr-2" />
                    {{ 'edit'|trans|capitalize }}
                </twig:Xutim:Admin:Button>
                <twig:Xutim:Admin:Button
                    tag="a"
                    variant="dropdown"
                    data-turbo-frame="modal"
                    href="{{ admin_path('admin_menu_item_delete', {id: item.id}) }}"
                >
                    <twig:ux:icon name="ph:trash" class="icon mr-2" />
                    {{ 'delete'|trans|capitalize }}
                </twig:Xutim:Admin:Button>

                <div class="dropdown-divider"></div>

                <twig:Xutim:Admin:Button
                    tag="a"
                    variant="dropdown"
                    data-turbo-frame="modal"
                    href="{{ admin_path('admin_menu_item_new', {id: item.id}) }}"
                >
                    <twig:ux:icon name="ph:plus" class="icon" />
                    {{ 'New menu item'|trans({}, 'admin') }}
                </twig:Xutim:Admin:Button>

                {% if first is not same as(true) or last is not same as(true) %}
                    <div class="dropdown-divider"></div>

                    {% if first is not same as(true) %}
                        <twig:Xutim:Admin:Button
                            tag="a"
                            variant="dropdown"
                            href="{{ admin_path('admin_menu_item_move', {id: item.id, dir: 'up'}) }}"
                        >
                            <twig:ux:icon name="ph:arrow-up" class="icon mr-2" />
                            {{ 'move up'|trans({}, 'admin')|capitalize }}
                        </twig:Xutim:Admin:Button>
                    {% endif %}

                    {% if last is not same as(true) %}
                        <twig:Xutim:Admin:Button
                            tag="a"
                            variant="dropdown"
                            href="{{ admin_path('admin_menu_item_move', {id: item.id, dir: 'down'}) }}"
                        >
                            <twig:ux:icon name="ph:arrow-down" class="icon mr-2" />
                            {{ 'move down'|trans({}, 'admin')|capitalize }}
                        </twig:Xutim:Admin:Button>
                    {% endif %}
                {% endif %}
            </div>
        </div>
    {% endif %}
{% endmacro %}
