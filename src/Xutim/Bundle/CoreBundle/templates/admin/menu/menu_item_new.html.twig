{% extends '@XutimCore/admin/modalBase.html.twig' %}
{% import '@XutimCore/admin/common/forms.html.twig' as forms %}

{% block pageTitle %}{{ 'New menu item'|trans({}, 'admin')|capitalize }}{%
    endblock
%}

{% block body %}
    <div class="rounded-xl border border-border">
        <div class="p-4">
            {{
                form_start(form, {attr: {
                id: form.vars.id,
                'data-controller': 'menu-item',
                'data-menu-item-is-update-value': item is defined and item is not same as (null) ? true : false,
            }})
            }}
            {% if item is not defined or item is same as(null) %}
                <div class="mb-3">
                    <label class="text-sm font-medium text-content">
                        {{ 'Select a type of a menu item'|trans({}, 'admin') }}
                    </label>
                    <div class="inline-flex rounded-lg border border-border mt-2">
                        <label class="flex items-center gap-1 px-3 py-2 cursor-pointer border-r border-border text-sm has-[:checked]:bg-accent/10 has-[:checked]:text-accent rounded-l-lg">
                            <input
                                type="radio"
                                name="menu-item-type"
                                value="page"
                                class="sr-only"
                                data-action="click->menu-item#showPage"
                            />
                            <span class="flex items-center gap-1">
                                <twig:ux:icon name="ph:folder-simple" class="icon" />
                                {{ 'page'|trans({}, 'admin')|capitalize }}
                            </span>
                        </label>
                        <label class="flex items-center gap-1 px-3 py-2 cursor-pointer border-r border-border text-sm has-[:checked]:bg-accent/10 has-[:checked]:text-accent">
                            <input
                                type="radio"
                                name="menu-item-type"
                                value="article"
                                class="sr-only"
                                data-action="click->menu-item#showArticle"
                            />
                            <span class="flex items-center gap-1">
                                <twig:ux:icon name="ph:newspaper" class="icon" />
                                {{ 'article'|trans({}, 'admin')|capitalize }}
                            </span>
                        </label>
                        <label class="flex items-center gap-1 px-3 py-2 cursor-pointer text-sm has-[:checked]:bg-accent/10 has-[:checked]:text-accent rounded-r-lg">
                            <input
                                type="radio"
                                name="menu-item-type"
                                value="tag"
                                class="sr-only"
                                data-action="click->menu-item#showTag"
                            />
                            <span class="flex items-center gap-1">
                                <twig:ux:icon name="ph:tag" class="icon" />
                                {{ 'tag'|trans({}, 'admin')|capitalize }}
                            </span>
                        </label>
                    </div>
                </div>
            {% endif %}

            <div data-menu-item-target="pageForm">
                {{ form_row(form.page) }}
                <div class="mb-3" data-menu-item-target="overwriteCheckbox">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input
                            type="checkbox"
                            id="menu-item-overwrite"
                            class="rounded border-border text-accent focus:ring-accent"
                            value="0"
                            data-action="click->menu-item#togglePageOverwriteLink"
                        />
                        <span class="text-sm text-content">
                            {{ 'Overwrite link'|trans({}, 'admin') }}
                        </span>
                    </label>
                </div>
                <div
                    class="grid grid-cols-2 items-start gap-4 mb-3"
                    id="page-overwrite-link-form"
                    data-menu-item-target="pageOverwriteLinkForm"
                >
                    {{ form_row(form.pageLink, {row_attr: {class: ''}}) }}
                    {{
                        form_row(form.anchorSnippet, {row_attr: {class: ''}})
                    }}
                </div>
            </div>
            <div data-menu-item-target="articleForm">
                {{ form_row(form.article) }}
            </div>

            <div data-menu-item-target="tagForm">
                {{ form_row(form.tag) }}
            </div>

            <div class="mb-3" data-menu-item-target="submitButton">
                <twig:Xutim:Admin:Button
                    type="submit"
                    variant="primary"
                    id="menu_item_submit"
                    form="{{ form.vars.id }}"
                    role="submit"
                >
                    {{ 'submit'|trans({}, 'admin') }}
                </twig:Xutim:Admin:Button>
            </div>

            {{ form_row(form._token) }}
            {{ form_end(form, {render_rest: false}) }}
        </div>
    </div>
{% endblock %}

{% block stream_success %}
    <turbo-stream action="refresh"></turbo-stream>
    <turbo-stream action="update" target="modal">
        <template></template>
    </turbo-stream>
{% endblock %}
