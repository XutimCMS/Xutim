{% import '@XutimCore/admin/common/badges.html.twig' as badges %}

<div class="rounded-xl border border-border mb-3">
    <div class="border-b border-border px-4 py-3">
        <h3 class="text-sm font-semibold">
            <twig:ux:icon name="ph:translate" class="icon" />{{
                'all translations'|trans({}, 'admin')|capitalize
            }}
        </h3>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-[13px]">
            <thead>
                <tr class="border-b border-border bg-surface-raised text-left">
                    <th class="px-4 py-2.5 font-medium text-content-tertiary w-6" title="Status" data-controller="tooltip">
                        S
                    </th>
                    <th
                        class="px-4 py-2.5 font-medium text-content-tertiary w-1"
                        title="Translation reference"
                        data-controller="tooltip"
                    >
                        T
                    </th>
                    <th class="px-4 py-2.5 font-medium text-content-tertiary">{{ 'title'|trans({}, 'admin') }}</th>
                    <th class="px-4 py-2.5 font-medium text-content-tertiary">{{ 'language'|trans({}, 'admin') }}</th>
                    <th class="px-4 py-2.5 font-medium text-content-tertiary text-right">
                        {{ 'actions'|trans({}, 'admin') }}
                    </th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border">
                {% for translation in article.translations %}
                    <tr>
                        <td class="px-4 py-2.5 w-6">
                            <button
                                type="button"
                                role="button"
                                class="btn-link p-0 border-0"
                                data-bs-placement="bottom"
                                data-controller="popover"
                                data-bs-toggle="popover"
                                data-bs-selector="#changeStatus"
                            >
                                {{ badges.publicationStatusBadge(translation) }}
                            </button>
                        </td>
                        <td
                            class="px-4 py-2.5"
                            title="Translation reference"
                            data-controller="tooltip"
                        >
                            {%
                                if article.defaultTranslation.id == translation.id
                            %}
                                <span class="font-bold text-green-600 dark:text-green-400">
                                    <twig:ux:icon name="ph:translate" class="icon" />
                                </span>
                            {% else %}
                                <twig:Xutim:Admin:ModalDialog
                                    class="btn-link sm:inline-block px-0 border-0"
                                    action="{{ admin_path('admin_page_mark_default_translation', {id: article.id, transId: translation.id}) }}"
                                    confirmActionLabel="{{ 'action.mark_as_default'|trans({}, 'admin')|capitalize }}"
                                >
                                    <span
                                        class="inline-block h-2 w-2 rounded-full bg-content-secondary"
                                    ></span>
                                </twig:Xutim:Admin:ModalDialog>
                            {% endif %}
                        </td>
                        <td class="px-4 py-2.5 text-content-secondary">
                            {{ translation.title }}
                            {%
                                if article.defaultTranslation.id == translation.id
                            %}
                                ({{
                                    'reference for translations'|trans({}, 'admin')
                                }})
                            {% endif %}
                        </td>
                        <td class="px-4 py-2.5 text-content-secondary">
                            {{ translation.locale|locale_name }}
                        </td>
                        <td class="px-4 py-2.5">
                            <div class="flex justify-end items-center">
                                <a
                                    href="{{ path('content_translation_show', {_locale: translation.locale, slug: translation.slug}) }}"
                                    class="btn-link mr-2 {% if not translation.status.isPublished() %}disabled{% endif %}"
                                    aria-label="{{ 'Show on public page'|trans({}, 'admin') }}"
                                    data-turbo="false"
                                >
                                    <twig:ux:icon name="ph:globe-simple" class="icon" />
                                </a>

                                {%
                                    if app.user.canTranslate(translation.locale)
                                %}
                                    <a
                                        href="{{ admin_path('admin_content_translation_revisions', {id: translation.id}) }}"
                                        class="btn-link"
                                        aria-label="{{ 'revisions'|trans({}, 'admin') }}"
                                    >
                                        <twig:ux:icon name="ph:clock-counter-clockwise" class="icon" />
                                    </a>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="border-t border-border px-4 py-3"></div>
</div>
