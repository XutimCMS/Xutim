{% extends '@XutimCore/admin/base.html.twig' %}

{% block pageTitle %}{{ 'articles'|trans({}, 'admin')|capitalize }}{% endblock %}

{% block pageMenu %}
    {% if is_granted(constant('Xutim\\SecurityBundle\\Security\\UserRoles::ROLE_EDITOR')) %}
        <twig:Xutim:Admin:Button
            tag="a"
            variant="nav"
            href="{{ admin_path('admin_article_new') }}"
        >
            <twig:ux:icon name="ph:newspaper" class="h-4 w-4 shrink-0" />
            {{ 'New article'|trans({}, 'admin') }}
        </twig:Xutim:Admin:Button>
    {% endif %}
{% endblock %}

{% block languageBar %}
    <twig:Xutim:Admin:LanguageContextBar
        class="flex justify-end items-center mb-2"
    />
{% endblock %}

{% block breadcrumbHeader %}
    <twig:Xutim:Admin:Breadcrumbs>
        <li class="breadcrumb-item">Articles</li>
    </twig:Xutim:Admin:Breadcrumbs>
{% endblock %}

{% block body %}
    {% set tagsOptions = [] %}
    {% for tag in fetch_tags() %}
        {% set tagsOptions = tagsOptions|merge([{label: tag.label, value: tag.id}]) %}
    {% endfor %}
    {%
        component 'Xutim:Admin:DataTable' with {
            frameId: 'articles-list',
            pager: articles,
            tableBodyId: 'articles-list-body',
            filter: filter,
            showChips: true,
            columns: [
                {
                    key: 'publicationStatus',
                    label: 'S'|trans({}, 'admin'),
                    sortable: true,
                    order: 'publicationStatus',
                    filter: {
                        type: 'select',
                        options: [
                            {label: 'Draft'|trans({}, 'admin'), value: 'draft'},
                            {label: 'Published'|trans({}, 'admin'), value: 'published'},
                            {label: 'Scheduled'|trans({}, 'admin'), value: 'scheduled'},
                        ],
                        placeholder: 'Any'|trans({}, 'admin'),
                        chipLabel: 'Status'|trans({}, 'admin'),
                        minWidth: '180px',
                    },
                    headerClass: 'w-6',
                },
                {
                    key: 'translationStatus',
                    label: 'Translation'|trans({}, 'admin'),
                    sortable: false,
                    filter: {
                        type: 'select',
                        options: [
                            {label: 'Translated'|trans({}, 'admin'), value: 'translated'},
                            {label: 'Missing'|trans({}, 'admin'), value: 'missing'},
                            {label: 'Using fallback'|trans({}, 'admin'), value: 'fallback'},
                        ],
                        placeholder: 'Any'|trans({}, 'admin'),
                        minWidth: '200px',
                    },
                    headerClass: 'w-20',
                },
                {
                    key: 'title',
                    label: 'Title'|trans({}, 'admin'),
                    sortable: true,
                    order: 'title',
                },
                {
                    key: 'tags',
                    label: 'Tags'|trans({}, 'admin'),
                    sortable: true,
                    order: 'tags',
                    filter: {
                        type: 'select',
                        options: tagsOptions,
                        placeholder: 'Any'|trans({}, 'admin'),
                        minWidth: '240px',
                    },
                },
                {
                    key: 'inNews',
                    label: 'In news'|trans({}, 'admin'),
                    sortable: true,
                    order: 'inNews',
                    filter: {
                        type: 'select',
                        options: [
                            {label: 'yes'|trans({}, 'admin'), value: 'true'},
                            {label: 'no'|trans({}, 'admin'), value: 'false'},
                        ],
                        placeholder: 'Any'|trans({}, 'admin'),
                        minWidth: '180px',
                    },
                    headerClass: 'w-20',
                },
                {
                    key: 'updatedAt',
                    label: 'Updated at'|trans({}, 'admin'),
                    sortable: true,
                    order: 'updatedAt',
                },
                {
                    key: 'publishedAt',
                    label: 'Published at'|trans({}, 'admin'),
                    sortable: true,
                    order: 'publishedAt',
                },
            ],
        }
    %}
    {% block body %}
        {% for article in articles %}
            {% set translation = article.translationByLocaleOrFallback(content_context_language(), default_locale) %}
            {% set inCurrentLocale = translation.locale == content_context_language() %}
            {% set excludeFromNews = false %}
            {% for tag in article.tags %}
                {% if tag.excludeFromNews %}{% set excludeFromNews = true %}{% endif %}
            {% endfor %}
            <twig:Xutim:Admin:Tr>
                <twig:Xutim:Admin:Td>
                    <twig:Xutim:Admin:StatusDot :status="inCurrentLocale ? translation.status : null" />
                </twig:Xutim:Admin:Td>
                <twig:Xutim:Admin:Td>
                    <span class="font-medium {{ inCurrentLocale ? 'text-accent' : 'text-amber-600 dark:text-amber-400' }}">{{ translation.locale|upper }}</span>
                </twig:Xutim:Admin:Td>
                <twig:Xutim:Admin:Td>
                    <div class="flex items-center gap-2">
                        <span class="inline-flex rounded border border-border px-1 py-0.5 text-[10px] font-medium text-content-tertiary">{{ translation.locale }}</span>
                        <a href="{{ admin_path('admin_article_show', {id: article.id, _content_locale: content_context.language}) }}"
                            data-turbo-frame="_top"
                            class="text-accent hover:underline"
                            aria-label="{{ 'show'|trans({}, 'admin') }}"
                        >{{ translation }}</a>
                    </div>
                </twig:Xutim:Admin:Td>
                <twig:Xutim:Admin:Td class="max-w-60">
                    <div class="flex flex-wrap gap-1">
                        {% for tag in article.tags %}
                            {% set tagName = tag.translationByLocaleOrAny(content_context_language(), default_locale).name %}
                            <twig:Xutim:Admin:Tag :color="tag.color" :title="tagName|length > 30 ? tagName : null">
                                {{ tagName|u.truncate(30, '...') }}
                            </twig:Xutim:Admin:Tag>
                        {% endfor %}
                    </div>
                </twig:Xutim:Admin:Td>
                <twig:Xutim:Admin:Td>
                    <twig:Xutim:Admin:BoolText :value="not excludeFromNews" />
                </twig:Xutim:Admin:Td>
                <twig:Xutim:Admin:Td class="text-content-secondary whitespace-nowrap">
                    <time datetime="{{ translation.updatedAt|date('c') }}"
                        title="{{ translation.updatedAt|format_datetime('long') }}"
                        data-controller="tooltip"
                    >{{ translation.updatedAt|time_ago() }}</time>
                </twig:Xutim:Admin:Td>
                <twig:Xutim:Admin:Td class="text-content-secondary whitespace-nowrap">
                    {% if translation.isScheduled() and article.scheduledAt %}
                        <time datetime="{{ article.scheduledAt|date('c') }}"
                            title="{{ article.scheduledAt|format_datetime('long') }}"
                            data-controller="tooltip"
                        >{{ article.scheduledAt|time_ago() }}</time>
                    {% elseif translation.publishedAt %}
                        <time datetime="{{ translation.publishedAt|date('c') }}"
                            title="{{ translation.publishedAt|format_datetime('long') }}"
                            data-controller="tooltip"
                        >{{ translation.publishedAt|time_ago() }}</time>
                    {% else %}
                        -
                    {% endif %}
                </twig:Xutim:Admin:Td>
            </twig:Xutim:Admin:Tr>
        {% endfor %}
    {% endblock %}
    {% endcomponent %}
{% endblock %}
