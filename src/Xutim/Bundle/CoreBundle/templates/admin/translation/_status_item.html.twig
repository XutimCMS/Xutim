{% macro modalDialogPage(id, status, confirmActionLabel, iconName) %}
    <twig:Xutim:Admin:ModalDialog
        class="text-{{ status.colorClass }}-600 hover:text-{{ status.colorClass }}-700 p-0"
        modalDialogColor="{{ status.colorClass }}"
        action="{{ admin_path('admin_event_publication_status_edit', {id: id, status: status.value}) }}"
        confirmActionLabel="{{ confirmActionLabel }}"
    >
        <twig:ux:icon :name="'ph:' ~ iconName" class="icon" />
    </twig:Xutim:Admin:ModalDialog>
{% endmacro %}
{% block stream_success %}
    <turbo-stream action="replace" targets="#translation-status-item">
        <template>
            <twig:Xutim:Admin:SidebarItem id="translation-status-item">
                <twig:block name="header">
                    {{ 'status'|trans({}, 'admin')|capitalize }}:
                </twig:block>

                <twig:block name="content">
                    <div>
                        <span
                            class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full bg-{{ translation.status.colorClass }}-100 text-{{ translation.status.colorClass }}-800 dark:bg-{{ translation.status.colorClass }}-900/30 dark:text-{{ translation.status.colorClass }}-300 mr-2"
                        >
                            {{ translation.status.name }}
                        </span>
                    </div>

                    {% if is_granted_translation(content_context_language()) %}
                        {%
                            from '@XutimCore/admin/translation/_status_item.html.twig' import modalDialogPage
                        %}
                        <div>
                            {% if translation.status.canBeDrafted() %}
                                {{
                                    modalDialogPage(translation.id, constant('Xutim\\CoreBundle\\Entity\\PublicationStatus::Draft'), 'draft'|trans({}, 'admin')|capitalize, 'clipboard')
                                }}
                            {% endif %}

                            {% if translation.status.canPublish %}
                                {{
                                    modalDialogPage(translation.id, constant('Xutim\\CoreBundle\\Entity\\PublicationStatus::Published'), 'publish'|trans({}, 'admin')|capitalize, 'cloud-arrow-up')
                                }}
                            {% endif %}

                            {% if translation.status.canSubmitForEvaluation %}
                                {{
                                    modalDialogPage(translation.id, constant('Xutim\\CoreBundle\\Entity\\PublicationStatus::Evaluation'), 'submit for evaluation'|trans({}, 'admin')|capitalize, 'arrows-clockwise')
                                }}
                            {% endif %}

                            {% if translation.status.canBeArchived %}
                                {{
                                    modalDialogPage(translation.id, constant('Xutim\\CoreBundle\\Entity\\PublicationStatus::Archived'), 'archive'|trans({}, 'admin')|capitalize, 'archive')
                                }}
                            {% endif %}
                        </div>
                    {% endif %}
                </twig:block>
            </twig:Xutim:Admin:SidebarItem>
        </template>
    </turbo-stream>
{% endblock %}
