{% if draft is defined and draft is not null %}
    <div class="rounded-lg border border-amber-300 bg-amber-50 dark:bg-amber-900/20 dark:border-amber-700 p-3 flex items-center justify-between mb-3">
        <div>
            <strong>{{ 'Unpublished changes'|trans({}, 'admin') }}</strong>
            <span class="text-content-secondary ml-1">{{ 'Last updated %date%'|trans({'%date%': draft.updatedAt|date('Y-m-d H:i')}, 'admin') }}</span>
        </div>
        <div class="flex gap-2">
            <twig:Xutim:Admin:ModalDialog
                class="px-3 py-1.5 text-sm font-medium rounded-lg bg-green-600 text-white hover:bg-green-700"
                modalDialogColor="success"
                action="{{ admin_path('admin_content_draft_publish', {draftId: draft.id}) }}"
                confirmActionLabel="{{ 'Publish'|trans({}, 'admin') }}"
            >
                {{ 'Publish'|trans({}, 'admin') }}
            </twig:Xutim:Admin:ModalDialog>
            <twig:Xutim:Admin:ModalDialog
                class="px-3 py-1.5 text-sm font-medium rounded-lg border border-red-300 text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20"
                modalDialogColor="danger"
                action="{{ admin_path('admin_content_draft_discard', {draftId: draft.id}) }}"
                confirmActionLabel="{{ 'Discard'|trans({}, 'admin') }}"
            >
                {{ 'Discard'|trans({}, 'admin') }}
            </twig:Xutim:Admin:ModalDialog>
        </div>
    </div>
{% endif %}
