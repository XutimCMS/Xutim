{% block image_choice_widget %}
    <div class="mb-4">
        <label class="block text-[12px] font-medium text-content-secondary mb-1.5">{{ form.vars.label }}</label>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
            {% for child in form %}
                <label class="relative cursor-pointer">
                    <input
                        type="radio"
                        id="{{ child.vars.name }}"
                        name="{{ child.vars.full_name }}"
                        value="{{ child.vars.value }}"
                        class="peer sr-only"
                        {% if child.vars.checked %}checked{% endif %}
                        {{ block('widget_attributes') }}
                    />
                    <div class="rounded-lg border-2 border-border overflow-hidden peer-checked:border-accent peer-checked:ring-1 peer-checked:ring-accent transition-colors">
                        <img
                            src="{{ child.vars.attr['data-image'] }}"
                            alt="{{ child.vars.label }}"
                            width="124"
                            height="82"
                            class="w-full h-auto"
                        />
                    </div>
                </label>
            {% endfor %}
        </div>
    </div>
{% endblock %}
