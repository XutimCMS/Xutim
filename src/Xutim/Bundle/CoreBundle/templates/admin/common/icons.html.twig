{% macro sprite(names) %}
    <svg
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        style="position: absolute; width: 0; height: 0; overflow: hidden"
    >
        {% for name in names %}
            {% set svg %}{% apply spaceless %}<twig:ux:icon
                        :name="'ph:'~name"
                    />{% endapply %}{% endset %}

            {{
                svg
        |replace({
          '<svg': '<symbol id="icon-' ~ name ~ '"',
          '</svg>': '</symbol>',
        })
        |raw
            }}
        {% endfor %}
    </svg>
{% endmacro %}

{% macro icon(name, class = '') %}
    <svg class="{{ class }}" aria-hidden="true" focusable="false">
        <use href="#{{ 'icon-' ~ name }}"></use>
    </svg>
{% endmacro %}

{% macro order_arrow(currentField, order, orderDirection) %}
    {% if currentField == order %}
        {% if orderDirection == 'asc' %}
            <twig:ux:icon name="ph:arrow-up" class="icon" />
        {% else %}
            <twig:ux:icon name="ph:arrow-down" class="icon" />
        {% endif %}
    {% else %}
        <twig:ux:icon name="ph:arrows-down-up" class="icon" />
    {% endif %}
{% endmacro %}

{% macro fileType(extension) %}
    {% set extensionIconMap = {
        'bmp': 'image',
        'css': 'file-css',
        'csv': 'file-csv',
        'doc': 'file-doc',
        'docx': 'file-doc',
        'html': 'file-html',
        'js': 'file-js',
        'pdf': 'file-pdf',
        'ppt': 'file-ppt',
        'sql': 'file-code',
        'svg': 'file-svg',
        'txt': 'file-text',
        'xls': 'file-xls',
        'xml': 'file-code',
        'zip': 'file-zip',
    } %}
    {% if extension in extensionIconMap|keys %}
        <twig:ux:icon :name="'ph:' ~ extensionIconMap[extension]" class="icon" />
    {% else %}
        <twig:ux:icon name="ph:file" class="icon" />
    {% endif %}
{% endmacro %}
