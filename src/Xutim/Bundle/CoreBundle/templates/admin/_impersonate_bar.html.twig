{% if is_granted('IS_IMPERSONATOR') %}
    <div class="bg-amber-500 dark:bg-amber-600 print:hidden">
        <div class="flex items-center justify-center gap-3 px-4 py-1.5 text-[12px] font-medium text-amber-950">
            <twig:ux:icon name="ph:user-switch" class="h-4 w-4" />
            <span>
                {{ 'You\'re watching the app as a user'|trans({}, 'admin')|capitalize }}
                <a href="{{ admin_path('admin_user_show', {id: app.user.id}) }}" class="font-bold underline">{{ app.user.email }}</a>
            </span>
            <a href="{{ impersonation_exit_path(admin_path('admin_user_list')) }}" class="rounded-md bg-amber-600 dark:bg-amber-700 px-2.5 py-0.5 text-amber-50 hover:bg-amber-700 dark:hover:bg-amber-800 transition-colors" data-turbo-prefetch="false">
                {{ 'Exit impersonation'|trans({}, 'admin')|capitalize }}
            </a>
        </div>
    </div>
{% endif %}
