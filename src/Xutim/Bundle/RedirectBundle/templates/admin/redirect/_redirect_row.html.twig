<tr id="redirect-row-{{ redirect.id }}">
    <td>
        <a
            href="{{ admin_path('admin_redirect_edit', {id: redirect.id}) }}"
            data-turbo-frame="modal"
        >
            {{ redirect.source }}
        </a>
    </td>
    <td>
        <a
            href="{{ redirect.target }}"
            data-turbo-frame="_top"
        >
            {{ redirect.target }}
            <twig:ux:icon name="ph:arrow-square-out" class="w-3 h-3" />
        </a>
    </td>
    <td>
        {% if redirect.permanent %}
            <span class="inline-flex items-center text-[12px] font-medium text-red-600 dark:text-red-400">
                {{ 'yes'|trans({}, 'admin') }}
            </span>
        {% else %}
            <span class="inline-flex items-center text-[12px] font-medium text-green-600 dark:text-green-400">
                {{ 'no'|trans({}, 'admin') }}
            </span>
        {% endif %}
    </td>
    <td>
        <twig:Xutim:Admin:ModalDialog
            class="inline-flex items-center rounded-md border border-red-300 text-red-600 px-3 py-1.5 text-[13px] font-medium hover:bg-red-50 dark:border-red-500/30 dark:text-red-400 dark:hover:bg-red-500/10 ml-auto"
            modalDialogColor="danger"
            action="{{ admin_path('admin_redirect_delete', {id: redirect.id}) }}"
            confirmActionLabel="{{ 'delete'|trans({}, 'admin')|capitalize }}"
        >
            <twig:ux:icon name="ph:trash" class="icon" />
            {{ 'delete'|trans({}, 'admin')|capitalize }}
        </twig:Xutim:Admin:ModalDialog>
    </td>
</tr>
