{% extends '@XutimCore/admin/base.html.twig' %}

{% block pageTitle %}Notifications{% endblock %}

{% block breadcrumbHeader %}
    <twig:Xutim:Admin:Breadcrumbs>
        <li><span class="text-content-tertiary/50">/</span></li>
        <li class="text-content">Notifications</li>
    </twig:Xutim:Admin:Breadcrumbs>
{% endblock %}

{% block pageMenu %}
    {% set unreadCount = notifications|filter(n => not n.read)|length %}
    {% if unreadCount > 0 %}
        <form method="post" action="{{ admin_path('admin_notification_read_all') }}">
            <twig:Xutim:Admin:Button variant="secondary" tag="button" type="submit">
                Mark all read ({{ unreadCount }})
            </twig:Xutim:Admin:Button>
        </form>
    {% endif %}
{% endblock %}

{% block body %}
    {% if notifications is empty %}
        <div class="rounded-xl border border-border">
            <div class="flex flex-col items-center justify-center py-12">
                <div class="flex h-12 w-12 items-center justify-center rounded-full bg-surface-raised mb-3">
                    <twig:ux:icon name="ph:bell-slash" width="24" height="24" class="text-content-tertiary" />
                </div>
                <p class="text-[13px] font-medium">No notifications</p>
                <p class="text-[12px] text-content-tertiary mt-1">You're all caught up.</p>
            </div>
        </div>
    {% else %}
        <div data-controller="notification-select">
            <div class="rounded-xl border border-border mb-3 hidden" data-notification-select-target="actions">
                <div class="px-4 py-2.5">
                    <form method="post" action="{{ admin_path('admin_notification_bulk') }}" class="flex items-center gap-3">
                        <input type="hidden" name="action" value="" />
                        <span class="text-[13px] text-content-secondary">
                            <span data-notification-select-target="count">0</span> selected
                        </span>
                        <twig:Xutim:Admin:Button variant="primary" type="button" data-action="notification-select#markRead">
                            <twig:ux:icon name="ph:envelope-open" width="14" height="14" />
                            Mark read
                        </twig:Xutim:Admin:Button>
                        <twig:Xutim:Admin:Button variant="secondary" type="button" data-action="notification-select#markUnread">
                            <twig:ux:icon name="ph:envelope" width="14" height="14" />
                            Mark unread
                        </twig:Xutim:Admin:Button>
                    </form>
                </div>
            </div>

            {% set unread = notifications|filter(n => not n.read) %}
            {% set read = notifications|filter(n => n.read) %}

            {% if unread is not empty %}
                <div class="rounded-xl border border-border mb-3">
                    <div class="border-b border-border px-4 py-3">
                        <label class="text-sm font-semibold flex items-center gap-2 cursor-pointer">
                            <input
                                type="checkbox"
                                class="h-4 w-4 rounded border-border text-accent focus:ring-accent"
                                data-notification-select-target="selectAll"
                                data-action="notification-select#toggleAll"
                            />
                            Unread
                            <span class="flex h-5 min-w-5 items-center justify-center rounded-full bg-accent px-1.5 text-[10px] font-semibold text-white dark:text-black">{{ unread|length }}</span>
                        </label>
                    </div>
                    <div class="divide-y divide-border">
                        {% for notification in unread %}
                            {% include '@XutimNotification/admin/notification/_notification_row.html.twig' %}
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {% if read is not empty %}
                <div class="rounded-xl border border-border">
                    {% if unread is not empty %}
                        <div class="border-b border-border px-4 py-3">
                            <h3 class="text-sm font-semibold text-content-secondary">Earlier</h3>
                        </div>
                    {% endif %}
                    <div class="divide-y divide-border">
                        {% for notification in read %}
                            {% include '@XutimNotification/admin/notification/_notification_row.html.twig' %}
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </div>

        {% if notifications.nbPages > 1 %}
            <div class="flex items-center justify-between mt-4 text-[13px]">
                <span class="text-content-secondary">
                    Page {{ notifications.currentPage }} of {{ notifications.nbPages }}
                </span>
                <div class="flex items-center gap-1">
                    {% if notifications.hasPreviousPage %}
                        <a href="{{ admin_path('admin_notification_list', {page: notifications.previousPage}) }}" class="inline-flex items-center gap-1 rounded-md px-2.5 py-1 text-content-secondary hover:bg-surface-raised transition-colors">
                            <twig:ux:icon name="ph:caret-left" width="14" height="14" /> prev
                        </a>
                    {% else %}
                        <span class="inline-flex items-center gap-1 rounded-md px-2.5 py-1 text-content-tertiary">
                            <twig:ux:icon name="ph:caret-left" width="14" height="14" /> prev
                        </span>
                    {% endif %}
                    {% if notifications.hasNextPage %}
                        <a href="{{ admin_path('admin_notification_list', {page: notifications.nextPage}) }}" class="inline-flex items-center gap-1 rounded-md px-2.5 py-1 text-content-secondary hover:bg-surface-raised transition-colors">
                            next <twig:ux:icon name="ph:caret-right" width="14" height="14" />
                        </a>
                    {% else %}
                        <span class="inline-flex items-center gap-1 rounded-md px-2.5 py-1 text-content-tertiary">
                            next <twig:ux:icon name="ph:caret-right" width="14" height="14" />
                        </span>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    {% endif %}
{% endblock %}
