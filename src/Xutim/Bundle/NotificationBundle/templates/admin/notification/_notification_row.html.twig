{% set sColor = notification.severity.statusColor() %}
{% set iconBg = sColor == 'green' ? 'bg-green-50 dark:bg-green-500/10' : (sColor == 'yellow' ? 'bg-amber-50 dark:bg-amber-500/10' : (sColor == 'red' ? 'bg-red-50 dark:bg-red-500/10' : 'bg-surface-raised')) %}
{% set iconColor = sColor == 'green' ? 'text-green-600 dark:text-green-400' : (sColor == 'yellow' ? 'text-amber-600 dark:text-amber-400' : (sColor == 'red' ? 'text-red-600 dark:text-red-400' : 'text-content-tertiary')) %}
<div class="flex items-center gap-3 px-4 py-2 hover:bg-surface-raised transition-colors">
    <input
        type="checkbox"
        class="h-4 w-4 shrink-0 rounded border-border text-accent focus:ring-accent"
        value="{{ notification.id }}"
        data-notification-select-target="checkbox"
        data-action="notification-select#toggle"
    />
    <span class="block h-1.5 w-1.5 shrink-0 rounded-full {{ not notification.read ? 'bg-accent' : '' }}"></span>
    <div class="flex shrink-0 items-center justify-center rounded-full {{ iconBg }}" style="width:28px;height:28px">
        <twig:ux:icon :name="notification.severity.iconName()" width="14" height="14" class="{{ iconColor }}" />
    </div>
    <a href="{{ notification.actionUrl ?? '#' }}" class="flex-1 min-w-0">
        <span class="text-[13px] font-medium {{ notification.read ? 'text-content-secondary' : '' }}">{{ notification.title }}</span>
        <p class="text-[12px] text-content-tertiary mt-0.5">{{ notification.body }}</p>
    </a>
    <span class="text-[11px] text-content-tertiary whitespace-nowrap shrink-0">{{ notification.createdAt|format_datetime('short', 'short') }}</span>
</div>
