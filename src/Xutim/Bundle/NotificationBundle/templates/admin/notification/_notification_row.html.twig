<div class="list-group-item py-3">
    <div class="d-flex align-items-center gap-3">
        <span class="avatar avatar-sm rounded-circle bg-{{ notification.severity.statusColor() }}-lt text-{{ notification.severity.statusColor() }}">
            <twig:ux:icon :name="notification.severity.iconName()" class="icon" />
        </span>
        <a href="{{ notification.actionUrl ?? '#' }}" class="flex-fill min-w-0 text-reset text-decoration-none">
            <div class="text-truncate{{ not notification.read ? ' fw-semibold' : ' text-secondary' }}">
                {{ notification.title }}
            </div>
            <div class="text-secondary text-truncate small">
                {{ notification.body }}
            </div>
        </a>
        <span class="text-secondary text-nowrap small d-none d-sm-inline">
            {{ notification.createdAt|format_datetime('short', 'short') }}
        </span>
        {% if not notification.read %}
            <form method="post" action="{{ admin_path('admin_notification_read', {id: notification.id}) }}">
                <button type="submit" class="btn btn-sm d-inline-flex align-items-center gap-1">
                    <twig:ux:icon name="tabler:check" class="icon text-success" />
                    {{ 'Done'|trans({}, 'admin') }}
                </button>
            </form>
        {% else %}
            <form method="post" action="{{ admin_path('admin_notification_unread', {id: notification.id}) }}">
                <button type="submit" class="btn btn-sm d-inline-flex align-items-center gap-1 text-secondary">
                    <twig:ux:icon name="tabler:arrow-back-up" class="icon" />
                    {{ 'Undo'|trans({}, 'admin') }}
                </button>
            </form>
        {% endif %}
    </div>
</div>
