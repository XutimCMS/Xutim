{% extends '@XutimSecurity/security/security_base.html.twig' %}

{% block title %}{{ 'Sign in'|trans({}, 'admin') }}{% endblock %}

{% block body %}
    <div class="flex justify-center mb-8">
        {% block loginLogo %}
            <svg class="h-10 w-10" viewBox="0 0 28 28" fill="currentColor">
                <circle cx="7" cy="7" r="2.5"/><circle cx="19" cy="7" r="2.5"/>
                <circle cx="7" cy="15" r="2.5"/><circle cx="14" cy="15" r="2.5"/>
                <circle cx="14" cy="23" r="2.5"/><circle cx="21" cy="23" r="2.5"/>
            </svg>
        {% endblock %}
    </div>

    <h1 class="text-xl font-semibold text-center mb-1">{{ 'Sign in to'|trans({}, 'admin') }} {% block loginTitle %}Xutim{% endblock %}</h1>
    <p class="text-[13px] text-content-secondary text-center mb-6">{{ 'Enter your credentials to access the admin'|trans({}, 'admin') }}</p>

    {% if error %}
        <twig:Xutim:Admin:Alert type="error" :message="error.messageKey|trans(error.messageData, 'security')" class="mb-4" />
    {% endif %}
    {% for flashMessage in app.session.flashbag.get('success') %}
        <twig:Xutim:Admin:Alert type="success" :message="flashMessage" class="mb-4" />
    {% endfor %}

    <form id="login-form" method="post" autocomplete="off" class="space-y-4">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}" />

        <div>
            <label for="email" class="block text-[12px] font-medium text-content-secondary mb-1">{{ 'email address'|trans({}, 'admin')|capitalize }}</label>
            <div class="relative">
                <twig:ux:icon name="ph:envelope" class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-content-tertiary pointer-events-none" />
                <input id="email" name="email" type="email" required tabindex="1" autofocus autocomplete="off" placeholder="{{ 'your@email.com'|trans({}, 'admin') }}" class="w-full rounded-lg border border-border bg-surface py-2.5 pl-9 pr-3 text-[13px] focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent" />
            </div>
        </div>

        <div>
            <div class="flex items-center justify-between mb-1">
                <label for="password" class="block text-[12px] font-medium text-content-secondary">{{ 'password'|trans({}, 'admin')|capitalize }}</label>
                <a href="{{ path('admin_forgot_password_request') }}" class="text-[11px] text-accent hover:underline">{{ 'I forgot password'|trans({}, 'admin') }}</a>
            </div>
            <div class="relative">
                <twig:ux:icon name="ph:lock" class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-content-tertiary pointer-events-none" />
                <input id="password" name="password" type="password" required tabindex="2" placeholder="{{ 'your password'|trans({}, 'admin')|capitalize }}" class="w-full rounded-lg border border-border bg-surface py-2.5 pl-9 pr-3 text-[13px] focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent" />
            </div>
        </div>

        <div>
            <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" id="remember_me" name="_remember_me" tabindex="3" class="h-3.5 w-3.5 rounded border-border text-accent focus:ring-accent" />
                <span class="text-[12px] text-content-secondary">{{ 'remember me on this device'|trans({}, 'admin')|capitalize }}</span>
            </label>
        </div>

        <button type="submit" tabindex="4" id="login-submit" class="w-full rounded-lg bg-accent py-2.5 text-[13px] font-medium text-white hover:bg-accent-hover dark:text-black transition-colors cursor-pointer">
            {{ 'sign in'|trans({}, 'admin')|capitalize }}
        </button>
    </form>
{% endblock %}
