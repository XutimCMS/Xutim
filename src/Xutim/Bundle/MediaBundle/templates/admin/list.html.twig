{% extends '@XutimCore/admin/base.html.twig' %}

{% block pageTitle %}
    {{ include('@XutimMedia/admin/_title.html.twig') }}
{% endblock %}

{% block breadcrumbHeader %}
    <twig:Xutim:Admin:Breadcrumbs>
        <li class="breadcrumb-item">
            <a href="{{ admin_path('admin_media_list') }}">{{
                'Media'|trans({}, 'admin')
            }}</a>
        </li>

        {% if currentFolder %}
            <li class="breadcrumb-item active" aria-current="page">
                {{ currentFolder.name() }}
            </li>
        {% endif %}
    </twig:Xutim:Admin:Breadcrumbs>
{% endblock %}

{% block pageMenu %}
    <div class="flex items-center">
        <div class="mr-3 items-center">
            <div class="relative">
                <form method="GET" action="" data-controller="auto-submit">
                    <input
                        type="text"
                        id="searchTerm"
                        name="searchTerm"
                        autofocus
                        class="form-control"
                        aria-label="{{ 'search'|trans({}, 'admin')|capitalize }}"
                        value="{{ searchTerm }}"
                        data-action="auto-submit#debouncedSubmit"
                        onfocus="var temp_value=this.value; this.value=''; this.value=temp_value"
                    />
                    <span class="absolute right-3 top-1/2 -translate-y-1/2 text-content-secondary">
                        <twig:ux:icon name="ph:magnifying-glass" class="icon" />
                    </span>
                </form>
            </div>
        </div>
    </div>
    <twig:Xutim:Admin:Button
        tag="a"
        variant="nav"
        data-turbo-frame="modal"
        href="{{ admin_path('admin_media_folder_new', {id: currentFolder.id()|default(null)}) }}"
    >
        <twig:ux:icon name="ph:folder-simple" class="icon mr-1" />
        {{ 'New folder'|trans({}, 'admin') }}
    </twig:Xutim:Admin:Button>

    <twig:Xutim:Admin:Button
        tag="a"
        variant="nav"
        data-turbo-frame="modal"
        href="{{ admin_path('admin_media_upload', {id: currentFolder.id()|default(null)}) }}"
    >
        <twig:ux:icon name="ph:image" class="icon mr-1" />
        {{ 'New file'|trans({}, 'admin') }}
    </twig:Xutim:Admin:Button>
{% endblock %}

{% block body %}
    {% if not searchTerm %}
        {% if folders is not empty %}
            <div class="flex items-center justify-between mb-2">
                <h2 class="text-lg font-semibold">
                    {{ 'Folders'|trans({}, 'admin') }}
                </h2>
            </div>
        {% endif %}

        <div
            class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3 mb-4"
            id="media-folder-list"
        >
            {% for folder in folders %}
                <div
                    class="flex-1"
                    id="folder-{{ folder.id() }}"
                    data-controller="drop-target"
                    data-drop-target-id-value="{{ folder.id() }}"
                    data-drop-target-move-url-value="{{ admin_path('admin_media_move_file_to_folder') }}"
                    data-action="dragover->drop-target#over dragleave->drop-target#leave drop->drop-target#drop"
                >
                    <a
                        class="rounded-xl border border-border block hover:border-accent transition-colors"
                        href="{{ admin_path('admin_media_list', {id: folder.id()}) }}"
                        data-drop-target-target="folderCard"
                    >
                        <div
                            class="p-4"
                            data-drop-target-target="folderCard"
                        >
                            <div class="flex items-center gap-2 mb-2">
                                <twig:ux:icon name="ph:folder-simple" class="icon" />
                                <div class="grow truncate font-medium" title="{{ folder.name() }}">
                                    {{ folder.name() }}
                                </div>
                            </div>
                            <div class="text-content-secondary text-sm">
                                {{ folder.children()|length }}
                                {{ 'folders'|trans({}, 'admin') }},
                                {{ folder.media()|length }}
                                {{ 'files'|trans({}, 'admin') }}
                            </div>
                        </div>
                    </a>
                </div>
            {% endfor %}
            <div class="flex-1">
                <twig:Xutim:Admin:Button
                    tag="a"
                    variant="card-link"
                    style="border-style: dashed"
                    data-turbo-frame="modal"
                    href="{{ admin_path('admin_media_folder_new', {id: currentFolder.id()|default(null)}) }}"
                >
                    <div
                        class="p-4 flex items-center gap-2 text-black text-opacity-25"
                        data-drop-target-target="folderCard"
                    >
                        <twig:ux:icon name="ph:plus" class="icon" />
                        <div class="grow">
                            <div class="font-medium truncate">
                                {{ 'New folder'|trans({}, 'admin') }}
                            </div>
                        </div>
                    </div>
                </twig:Xutim:Admin:Button>
            </div>
        </div>
    {% endif %}

    {% if media is not empty %}
        <div class="flex items-center justify-between mb-2">
            <h2 class="text-lg font-semibold">
                {{ 'Files'|trans({}, 'admin') }}
            </h2>
        </div>
    {% endif %}
    <div
        class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3"
        id="media-list"
    >
        {% for item in media %}
            <div
                class="flex-1"
                id="media-{{ item.id() }}"
                data-controller="draggable"
                data-draggable-id-value="{{ item.id() }}"
                data-draggable-name-value="{{ item.originalPath() }}"
                draggable="true"
                data-action="dragstart->draggable#start dragend->draggable#end"
            >
                <div class="rounded-xl border border-border">
                    <div class="relative">
                        <a
                            href="{{ admin_path('admin_media_edit', {id: item.id()}) }}"
                            class="block"
                        >
                            {% if item.isImage() %}
                                <twig:XutimMedia:Admin:Picture
                                    :media="item"
                                    preset="thumb_small"
                                    alt=""
                                    class="w-full rounded-t-xl object-cover"
                                />
                            {% else %}
                                <div class="w-full rounded-t-xl flex items-center justify-center bg-surface-raised" style="aspect-ratio: 1; min-height: 120px;">
                                    {% if item.mime() starts with 'application/pdf' %}
                                        <twig:ux:Icon name="ph:file-pdf" class="text-danger" style="width: 3rem; height: 3rem;" />
                                    {% elseif item.mime() starts with 'video/' %}
                                        <twig:ux:Icon name="ph:file-video" class="text-primary" style="width: 3rem; height: 3rem;" />
                                    {% elseif item.mime() starts with 'audio/' %}
                                        <twig:ux:Icon name="ph:file-audio" class="text-info" style="width: 3rem; height: 3rem;" />
                                    {% elseif item.mime() starts with 'text/' or item.mime() in ['application/json', 'application/xml'] %}
                                        <twig:ux:Icon name="ph:file-text" class="text-content-secondary" style="width: 3rem; height: 3rem;" />
                                    {% else %}
                                        <twig:ux:Icon name="ph:file" class="text-content-secondary" style="width: 3rem; height: 3rem;" />
                                    {% endif %}
                                </div>
                            {% endif %}
                        </a>
                        <div class="absolute top-0 right-0 m-2">
                            <div class="dropdown">
                                <button
                                    class="inline-flex items-center justify-center rounded-md p-1.5 bg-white/80 dark:bg-surface-raised hover:bg-white dark:hover:bg-surface-raised/80 shadow-sm"
                                    type="button"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false"
                                >
                                    <twig:ux:Icon
                                        name="ph:dots-three-vertical"
                                        class="w-3 h-3"
                                    />
                                </button>
                                <div class="absolute rounded-xl border border-border bg-surface shadow-lg py-1 z-50">
                                    <a
                                        class="flex items-center gap-2 px-3 py-1.5 hover:bg-surface-raised rounded"
                                        href="{{ admin_path('admin_media_edit', {id: item.id()}) }}"
                                    >
                                        <twig:ux:icon name="ph:pencil-simple" class="icon mr-2" />
                                        {{ 'Edit'|trans({}, 'admin') }}
                                    </a>
                                    <a
                                        class="flex items-center gap-2 px-3 py-1.5 hover:bg-surface-raised rounded"
                                        href="{{ admin_path('admin_media_move', {id: item.id()}) }}"
                                        data-turbo-frame="modal"
                                    >
                                        <twig:ux:icon name="ph:folder-simple" class="icon mr-2" />
                                        {{ 'Move to folder'|trans({}, 'admin') }}
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="p-4 border-t border-border">
                        <div
                            class="flex items-center truncate"
                            title="{{ item.innerName() }}"
                            data-controller="tooltip"
                        >
                            {{ item.innerName() }}
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
    <div class="flex justify-center mt-4">
        {% set pages = media.nbPages %}
        {% if pages > 1 %}
            {% if media.currentPage - 3 > 0 %}
                <span class="text-black p-2 px-3 inline-block rounded">
                    ...
                </span>
            {% endif %}
            {% if media.currentPage - 2 > 0 %}
                <a
                    href="{{ admin_path('admin_media_list', {id: currentFolder.id()|default(null), searchTerm: searchTerm, page: media.currentPage - 2}) }}"
                    class="text-black p-2 px-3 inline-block rounded"
                >
                    {{ media.currentPage - 2 }}
                </a>
            {% endif %}
            {% if media.currentPage - 1 > 0 %}
                <a
                    href="{{ admin_path('admin_media_list', {id: currentFolder.id()|default(null), searchTerm: searchTerm, page: media.currentPage - 1}) }}"
                    class="text-black p-2 px-3 inline-block rounded"
                >
                    {{ media.currentPage - 1 }}
                </a>
            {% endif %}
            <a
                href="{{ admin_path('admin_media_list', {id: currentFolder.id()|default(null), searchTerm: searchTerm, page: media.currentPage}) }}"
                disabled="disabled"
                class="bg-gray-200 text-black p-2 px-3 inline-block rounded"
            >
                {{ media.currentPage }}
            </a>
            {% if media.currentPage + 1 <= pages %}
                <a
                    href="{{ admin_path('admin_media_list', {id: currentFolder.id()|default(null), searchTerm: searchTerm, page: media.currentPage + 1}) }}"
                    class="text-black p-2 px-3 inline-block rounded"
                >
                    {{ media.currentPage + 1 }}
                </a>
            {% endif %}
            {% if media.currentPage + 2 <= pages %}
                <a
                    href="{{ admin_path('admin_media_list', {id: currentFolder.id()|default(null), searchTerm: searchTerm, page: media.currentPage + 2}) }}"
                    class="text-black p-2 px-3 inline-block rounded"
                >
                    {{ media.currentPage + 2 }}
                </a>
            {% endif %}

            {% if media.currentPage + 3 <= pages %}
                <span class="text-black p-2 px-3 inline-block rounded">
                    ...
                </span>
            {% endif %}
        {% endif %}
    </div>
{% endblock %}
