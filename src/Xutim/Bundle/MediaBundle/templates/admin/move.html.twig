{% extends '@XutimCore/admin/modalBase.html.twig' %}

{% set title = 'Move file'|trans({}, 'admin') %}

{% block pageTitle %}
    {{ title }}
{% endblock %}

{% block body %}
    <div class="rounded-xl border border-border">
        <div class="border-b border-border px-4 py-3">
            <h3 class="text-base font-semibold">{{ title }}</h3>
        </div>
        <div class="p-4">
            <div class="mb-3">
                <label class="form-label">
                    {{ 'Select destination folder'|trans({}, 'admin') }}
                </label>
                <div class="flex flex-col divide-y divide-border rounded-xl border border-border">
                    <a
                        href="{{ admin_path('admin_media_move', {id: media.id, folderId: ''}) }}"
                        class="flex items-center gap-2 px-3 py-1.5 hover:bg-surface-raised rounded-lg {% if currentFolder is null %}active{% endif %}"
                        data-turbo-method="post"
                    >
                        <div class="flex items-center">
                            <twig:ux:icon name="ph:house" class="icon mr-2" />
                            <div>
                                <div class="font-medium">
                                    {{ 'Root'|trans({}, 'admin') }}
                                </div>
                                <div class="text-content-secondary text-sm">
                                    {{ 'No folder'|trans({}, 'admin') }}
                                </div>
                            </div>
                        </div>
                    </a>
                    {% for folder in folders %}
                        <a
                            href="{{ admin_path('admin_media_move', {id: media.id, folderId: folder.id}) }}"
                            class="flex items-center gap-2 px-3 py-1.5 hover:bg-surface-raised rounded-lg {% if currentFolder and currentFolder.id == folder.id %}active{% endif %}"
                            data-turbo-method="post"
                        >
                            <div class="flex items-center">
                                <twig:ux:icon name="ph:folder-simple" class="icon mr-2" />
                                <div class="grow">
                                    <div class="font-medium">
                                        {{ folder.name }}
                                    </div>
                                    <div class="text-content-secondary text-sm">
                                        {% set path = folder.folderPath %}
                                        {% if path|length > 1 %}
                                            {% for pathFolder in path %}
                                                {{ pathFolder.name }}{% if not loop.last %}
                                                    /{% endif %}
                                            {% endfor %}
                                        {% else %}
                                            {{ 'Root'|trans({}, 'admin') }}
                                            / {{ folder.name }}
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block stream_remove_file %}
    <turbo-stream action="remove" target="media-{{ media.id }}">
    </turbo-stream>
{% endblock %}

{% block stream_update_folder %}
    <turbo-stream action="replace" target="folder-{{ folder.id }}">
        <template>
            {{ include('@XutimMedia/admin/_folder_card.html.twig', {folder: folder}) }}
        </template>
    </turbo-stream>
{% endblock %}
