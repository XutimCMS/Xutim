{% extends '@XutimCore/admin/modalBase.html.twig' %}
{% set title = 'replace file'|trans({}, 'admin')|capitalize %}

{% block pageTitle %}
    {{ title }}
{% endblock %}

{% block body %}
    <div class="rounded-xl border border-border">
        <div class="border-b border-border px-4 py-3">
            <h3 class="text-base font-semibold">{{ title }}</h3>
        </div>
        <div class="p-4">
            <div class="rounded-lg border border-blue-200 bg-blue-50 p-3 text-blue-800 dark:border-blue-500/30 dark:bg-blue-500/10 dark:text-blue-300 mb-3">
                {{ 'Only %ext% files are accepted.'|trans({'%ext%': media.originalExt|upper}, 'admin') }}
            </div>
            {{ form_start(form) }}
            {{ form_row(form.file) }}
            {{ form_row(form.submit) }}
            {{ form_row(form._token) }}
            {{ form_end(form, {render_rest: false}) }}
        </div>
    </div>
{% endblock %}
